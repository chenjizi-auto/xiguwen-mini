.price-detail-page { min-height: 100vh; background: radial-gradient(circle at top right, rgba(47,107,255,0.14), transparent 34%), linear-gradient(180deg, #f8fbff 0%, #f5f6fa 220rpx, #f5f6fa 100%); }
.hero { padding: 40rpx 28rpx 28rpx; color: #fff; background: linear-gradient(135deg, #2f6bff 0%, #5ba5ff 100%); }
.hero-label { font-size: 24rpx; line-height: 34rpx; color: rgba(255,255,255,0.82); }
.hero-price { margin-top: 10rpx; font-size: 52rpx; line-height: 64rpx; font-weight: 700; }
.content { padding: 20rpx 24rpx 40rpx; }
.state-error, .empty, .loading { padding: 120rpx 32rpx; text-align: center; color: #8b90a0; font-size: 28rpx; }
.retry { margin-top: 22rpx; color: #2f6bff; }
.group-card { margin-bottom: 20rpx; border-radius: 28rpx; overflow: hidden; background: #fff; box-shadow: 0 12rpx 30rpx rgba(18,31,53,0.06); }
.group-head { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding: 26rpx 28rpx; background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%); }
.group-title { color: #1f2329; font-size: 30rpx; font-weight: 700; }
.group-subtotal { color: #2f6bff; font-size: 24rpx; font-weight: 600; }
.detail-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; padding: 22rpx 28rpx; border-top: 1rpx solid #eef1f6; }
.detail-name { flex: 1; min-width: 0; color: #4a5260; font-size: 26rpx; line-height: 36rpx; }
.detail-price { flex-shrink: 0; color: #1f2329; font-size: 26rpx; font-weight: 600; line-height: 36rpx; }
