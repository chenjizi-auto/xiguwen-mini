<view class="publish-page">
  <view class="publish-nav" style="height: {{navHeight}}px; padding-top: {{navTop}}px; padding-right: {{menuRight}}px;">
    <view class="publish-nav-left" style="height: {{menuHeight}}px; line-height: {{menuHeight}}px;" bindtap="handleBack">取消</view>
    <view class="publish-nav-title" style="line-height: {{menuHeight}}px;">写动态</view>
    <view
      class="publish-nav-right {{canPublish ? 'publish-nav-right--active' : ''}}"
      style="height: {{menuHeight}}px; line-height: {{menuHeight}}px;"
      bindtap="onPublish"
    >
      {{submitting ? '发布中' : '发布'}}
    </view>
  </view>

  <view class="publish-divider"></view>

  <view class="publish-content">
    <textarea
      class="publish-textarea"
      maxlength="-1"
      auto-height
      cursor-spacing="140"
      placeholder="{{placeholder}}"
      placeholder-class="publish-placeholder"
      value="{{content}}"
      bindinput="onContentInput"
    />

    <view class="publish-grid">
      <view wx:for="{{images}}" wx:key="*this" class="publish-grid-item">
        <image
          class="publish-image"
          src="{{item}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-url="{{item}}"
        />
        <image class="publish-delete" src="/images/icon/close0.svg" mode="aspectFit" bindtap="removeImage" data-index="{{index}}" />
      </view>

      <view wx:if="{{showAddCell}}" class="publish-grid-item publish-grid-item--add" bindtap="onAddImage">
        <view class="publish-add-plus">+</view>
        <view class="publish-add-tip">继续添加</view>
      </view>
    </view>

    <view class="publish-footer-action" bindtap="onAddImage">
      <view class="publish-footer-action__main">
        <van-icon name="photo-o" size="20" color="#999999" />
        <text class="publish-footer-action__text">添加图片</text>
      </view>
      <text class="publish-footer-action__count">{{images.length}}/{{maxImageCount}}</text>
    </view>
  </view>
</view>
