page {
  min-height: 100%;
  background: #ffffff;
}

.publish-page {
  min-height: 100vh;
  background: #ffffff;
}

.publish-nav {
  position: relative;
  box-sizing: border-box;
  background: #ffffff;
}

.publish-nav-left,
.publish-nav-right {
  position: absolute;
  top: 0;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #666666;
}

.publish-nav-left {
  left: 0;
}

.publish-nav-right {
  right: 0;
}

.publish-nav-right--active {
  color: #e64340;
  font-weight: 600;
}

.publish-nav-title {
  margin: 0 160rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #222222;
}

.publish-divider {
  height: 2rpx;
  background: #f0f0f0;
}

.publish-content {
  padding: 0 0 32rpx;
}

.publish-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 500rpx;
  padding: 32rpx;
  font-size: 32rpx;
  line-height: 1.7;
  color: #222222;
  background: #ffffff;
}

.publish-placeholder {
  color: #b3b3b3;
}

.publish-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
}

.publish-grid-item {
  position: relative;
  width: 222rpx;
  height: 222rpx;
  margin: 10rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
  border: 2rpx solid #f1f1f1;
  box-sizing: border-box;
}

.publish-image {
  width: 100%;
  height: 100%;
}

.publish-delete {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
}

.publish-grid-item--add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.publish-add-plus {
  font-size: 72rpx;
  line-height: 72rpx;
  color: #c9c9c9;
}

.publish-add-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #b3b3b3;
}

.publish-footer-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  margin-top: 8rpx;
  padding: 0 32rpx;
  background: #f9f9f9;
}

.publish-footer-action__main {
  display: flex;
  align-items: center;
}

.publish-footer-action__text {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #999999;
}

.publish-footer-action__count {
  font-size: 24rpx;
  color: #b3b3b3;
}
