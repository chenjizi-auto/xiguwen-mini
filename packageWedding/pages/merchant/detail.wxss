.merchant-page {
  min-height: 100vh;
  padding-bottom: 132rpx;
  background: #f6f7fb;
}

.merchant-loading,
.merchant-state {
  padding: 120rpx 24rpx;
  text-align: center;
  color: #8a8d93;
  font-size: 26rpx;
}

.merchant-to-top {
  position: fixed;
  right: 24rpx;
  bottom: 170rpx;
  z-index: 20;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(31, 35, 41, 0.82);
  color: #fff;
  font-size: 22rpx;
  line-height: 76rpx;
  text-align: center;
}

.merchant-hero {
  position: relative;
  padding: calc(env(safe-area-inset-top) + 24rpx) 24rpx 28rpx;
  background: linear-gradient(180deg, #dbe8ff 0%, #eef3fb 100%);
  background-size: cover;
  background-position: center;
  overflow: hidden;
}

.merchant-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(8, 18, 38, 0.18), rgba(8, 18, 38, 0.58));
}

.merchant-hero-main {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 22rpx 22rpx 46rpx;
}

.merchant-avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.32);
  background: rgba(255, 255, 255, 0.28);
  flex-shrink: 0;
}

.merchant-main {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.merchant-name {
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
}

.merchant-occupation {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 25rpx;
}

.merchant-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.merchant-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 20rpx;
}

.merchant-badge--ghost {
  background: rgba(15, 23, 42, 0.22);
}

.merchant-address {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
  line-height: 1.6;
}

.merchant-score-card {
  position: relative;
  z-index: 2;
  margin-top: -10rpx;
  display: flex;
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx 12rpx;
  box-shadow: 0 14rpx 36rpx rgba(18, 31, 53, 0.08);
}

.merchant-score-item {
  flex: 1;
  text-align: center;
}

.merchant-score-value {
  color: #1f2329;
  font-size: 32rpx;
  font-weight: 700;
}

.merchant-score-label {
  margin-top: 8rpx;
  color: #8a8d93;
  font-size: 22rpx;
}

.merchant-summary-card,
.merchant-card {
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 32rpx rgba(18, 31, 53, 0.06);
}

.merchant-summary-title,
.merchant-section-title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 700;
}

.merchant-summary-text,
.merchant-section-desc {
  margin-top: 18rpx;
  color: #4b4f56;
  font-size: 25rpx;
  line-height: 1.8;
}

.merchant-tabs-wrap {
  margin-top: 20rpx;
  padding: 0 24rpx;
}

.merchant-tabs {
  white-space: nowrap;
}

.merchant-tab {
  display: inline-flex;
  align-items: center;
  margin-right: 16rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #edf1f8;
  color: #5c6675;
  font-size: 24rpx;
}

.merchant-tab-active {
  background: #1f2329;
  color: #fff;
  box-shadow: 0 10rpx 24rpx rgba(31, 35, 41, 0.18);
}

.merchant-content {
  padding-bottom: 24rpx;
}

.merchant-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.merchant-section-more {
  color: #2f6bff;
  font-size: 22rpx;
  flex-shrink: 0;
}

.merchant-section-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fef1f5;
  color: #fc5887;
  font-size: 20rpx;
  flex-shrink: 0;
}

.merchant-grid {
  display: grid;
  gap: 18rpx;
  margin-top: 20rpx;
}

.merchant-grid-two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.merchant-grid-three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.quote-card,
.work-card,
.team-card {
  overflow: hidden;
  border-radius: 22rpx;
  background: #f7f8fb;
}

.quote-cover,
.work-cover {
  width: 100%;
  height: 220rpx;
  background: #eef1f6;
}

.quote-title,
.work-title {
  padding: 16rpx 16rpx 0;
  color: #1f2329;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.quote-price {
  padding: 10rpx 16rpx 0;
  color: #ff5f3a;
  font-size: 28rpx;
  font-weight: 700;
}

.quote-meta,
.work-desc {
  padding: 10rpx 16rpx 16rpx;
  color: #8a8d93;
  font-size: 22rpx;
  line-height: 1.6;
}

.comment-card + .comment-card,
.dynamic-card + .dynamic-card,
.schedule-group + .schedule-group {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf1f8;
}

.comment-head,
.dynamic-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-avatar,
.team-avatar,
.dynamic-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #eef1f6;
}

.comment-main,
.dynamic-main {
  flex: 1;
  min-width: 0;
}

.comment-name,
.dynamic-name,
.team-name {
  color: #1f2329;
  font-size: 25rpx;
  font-weight: 600;
}

.comment-time,
.dynamic-time,
.team-role {
  margin-top: 8rpx;
  color: #8a8d93;
  font-size: 22rpx;
}

.comment-score {
  color: #ff8a00;
  font-size: 24rpx;
  font-weight: 600;
}

.comment-content,
.dynamic-content {
  margin-top: 16rpx;
  color: #4b4f56;
  font-size: 24rpx;
  line-height: 1.8;
}

.comment-images,
.dynamic-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.comment-image,
.dynamic-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  background: #eef1f6;
}

.comment-reply {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #f7f8fb;
}

.comment-reply-label {
  color: #2f6bff;
  font-size: 22rpx;
  font-weight: 600;
}

.comment-reply-content {
  margin-top: 10rpx;
  color: #4b4f56;
  font-size: 23rpx;
  line-height: 1.7;
}

.dynamic-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.dynamic-action {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f7f8fb;
  color: #8a8d93;
  font-size: 22rpx;
}

.dynamic-action-active {
  background: rgba(230, 67, 64, 0.12);
  color: #e64340;
}

.schedule-title {
  color: #fc5887;
  font-size: 26rpx;
  font-weight: 700;
}

.schedule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f7f8fb;
}

.schedule-date,
.schedule-box-date {
  color: #1f2329;
  font-size: 24rpx;
  font-weight: 600;
}

.schedule-slot,
.schedule-box-slot {
  color: #fc5887;
  font-size: 22rpx;
}

.schedule-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.schedule-box {
  width: 108rpx;
  min-height: 108rpx;
  margin: 0 16rpx 16rpx 0;
  padding: 18rpx 12rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #f7f8fb;
  box-shadow: 0 6rpx 16rpx rgba(18, 31, 53, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.team-card {
  padding: 18rpx 12rpx;
  text-align: center;
}

.team-price {
  margin-top: 8rpx;
  color: #ff5f3a;
  font-size: 22rpx;
}

.quote-list-empty {
  margin-top: 24rpx;
  text-align: center;
  color: #8a8d93;
  font-size: 24rpx;
}

.quote-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
}

.quote-row + .quote-row {
  border-top: 1rpx solid #edf1f8;
}

.quote-row-cover {
  width: 132rpx;
  height: 132rpx;
  border-radius: 20rpx;
  background: #eef1f6;
  flex-shrink: 0;
}

.quote-row-main {
  flex: 1;
  min-width: 0;
}

.quote-row-title {
  color: #1f2329;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.quote-row-meta {
  margin-top: 10rpx;
  color: #8a8d93;
  font-size: 22rpx;
}

.quote-row-price {
  color: #ff5f3a;
  font-size: 28rpx;
  font-weight: 700;
}

.merchant-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.merchant-row + .merchant-row {
  margin-top: 22rpx;
}

.merchant-label {
  color: #8a8d93;
  font-size: 26rpx;
}

.merchant-value {
  color: #2f3135;
  font-size: 26rpx;
  text-align: right;
}

.merchant-gallery {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.merchant-gallery-image {
  width: 100%;
  height: 180rpx;
  border-radius: 20rpx;
  background: #eef1f6;
}

.merchant-tab-footer {
  padding: 24rpx 24rpx 8rpx;
  text-align: center;
  color: #8a8d93;
  font-size: 22rpx;
}

.merchant-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 25;
  display: flex;
  align-items: stretch;
  padding: 0 0 calc(env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -10rpx 26rpx rgba(18, 31, 53, 0.08);
}

.merchant-bottom-icon {
  width: 150rpx;
  padding: 14rpx 0 12rpx;
  text-align: center;
}

.merchant-bottom-icon__symbol {
  color: #1f2329;
  font-size: 34rpx;
  line-height: 1.2;
}

.merchant-bottom-icon__text {
  margin-top: 6rpx;
  color: #5c6675;
  font-size: 22rpx;
}

.merchant-bottom-action {
  flex: 1;
  margin: 12rpx 24rpx 12rpx 0;
  border-radius: 999rpx;
  background: #e64340;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 76rpx;
  text-align: center;
}

@media (max-width: 520px) {
  .merchant-score-card {
    flex-wrap: wrap;
  }

  .merchant-score-item {
    width: 50%;
    margin-bottom: 12rpx;
  }
}
