<view class="balance-page">
  <view class="balance-hero">
    <view class="balance-hero-decoration balance-hero-decoration--one"></view>
    <view class="balance-hero-decoration balance-hero-decoration--two"></view>

    <view class="balance-nav" style="height:{{navHeight}}px;padding-top:{{navTop}}px;">
      <view class="balance-nav-inner" style="height:{{navHeight - navTop}}px;">
        <view class="balance-nav-side balance-nav-side--left" bindtap="goBack">
          <van-icon name="arrow-left" size="22" color="#ffffff" />
        </view>
        <view class="balance-nav-title">余额</view>
        <view class="balance-nav-side balance-nav-side--right" bindtap="goDetails">明细</view>
      </view>
    </view>

    <view class="balance-hero-main" style="padding-top:{{heroPaddingTop}}px;">
      <view class="balance-hero-label">账户余额（元）</view>
      <view class="balance-hero-amount">￥{{displayBalance}}</view>
    </view>
  </view>

  <view class="balance-actions">
    <view class="balance-action-card" bindtap="goWithdraw">
      <view class="balance-action-left">
        <view class="balance-action-icon">￥</view>
        <view class="balance-action-text">提现</view>
      </view>
      <image class="balance-action-arrow" src="/images/mine/icon_next_step.png" mode="aspectFit" />
    </view>
  </view>

  <view wx:if="{{loading}}" class="balance-loading">加载中...</view>
</view>
