.bill-form-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7fb;
}

.form-card {
  padding: 30rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 32rpx rgba(18, 31, 53, 0.06);
}

.type-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-chip {
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #667085;
  font-size: 26rpx;
}

.type-chip--active-expense {
  background: #fff0ee;
  color: #d9554b;
  font-weight: 700;
}

.type-chip--active-income {
  background: #edf9f1;
  color: #2f9a57;
  font-weight: 700;
}

.field-group + .field-group {
  margin-top: 24rpx;
}

.field-label {
  color: #231f20;
  font-size: 28rpx;
  font-weight: 700;
}

.field-input,
.picker-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 12rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f7f8fa;
  color: #222;
  font-size: 28rpx;
  box-sizing: border-box;
}
