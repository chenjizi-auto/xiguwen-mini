.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(230, 67, 64, 0.12), transparent 36%),
    linear-gradient(180deg, #fff8f6 0%, #f6f7fb 240rpx, #f6f7fb 100%);
}

.header {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 20rpx 24rpx 18rpx;
  background: rgba(246, 247, 251, 0.95);
  backdrop-filter: blur(18rpx);
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 22rpx;
  height: 84rpx;
  border-radius: 999rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(20, 24, 34, 0.05);
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.56;
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #222;
}

.search-btn {
  flex-shrink: 0;
  min-width: 80rpx;
  height: 64rpx;
  padding: 0 18rpx;
  margin-right: 4rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ff7e67 0%, #e64340 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 64rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(230, 67, 64, 0.18);
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-chip {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 1rpx solid #eceef2;
  color: #4e5969;
}

.filter-chip__text,
.filter-chip__arrow {
  font-size: 24rpx;
  line-height: 32rpx;
}

.content {
  padding: 20rpx 24rpx 40rpx;
}

.loading-box {
  padding: 120rpx 0;
}

.case-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.case-card {
  overflow: hidden;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 32rpx rgba(18, 24, 33, 0.06);
}

.case-cover-wrap {
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.case-cover {
  width: 100%;
  height: 100%;
  display: block;
  transform: scale(1.08);
  transform-origin: center;
}

.case-body {
  padding: 22rpx 24rpx 24rpx;
}

.case-author {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.case-author__main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.case-author__avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid #ffffff;
  box-sizing: border-box;
  background: #f3f4f6;
}

.case-author__name {
  min-width: 0;
  font-size: 24rpx;
  color: #666;
  line-height: 34rpx;
}

.case-follow {
  flex-shrink: 0;
  min-width: 112rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(230, 67, 64, 0.28);
  background: #fff7f6;
  color: #e64340;
  font-size: 22rpx;
  line-height: 30rpx;
  text-align: center;
}

.case-follow--active {
  border-color: #e9ebf0;
  background: #f5f6f8;
  color: #6b7280;
}

.case-title {
  margin-top: 14rpx;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  color: #20242c;
}

.case-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #7b7f87;
}

.case-footer {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
}

.case-price {
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 700;
  color: #e64340;
}

.case-meta {
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8c8f96;
}

.footer-text {
  padding: 20rpx 0 8rpx;
  text-align: center;
  color: #8c8f96;
  font-size: 24rpx;
  line-height: 34rpx;
}

.popup-sheet {
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.popup-title {
  text-align: center;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.popup-list {
  max-height: 720rpx;
  margin-top: 18rpx;
}

.popup-item {
  padding: 24rpx 18rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #333;
}

.popup-item + .popup-item {
  margin-top: 8rpx;
}

.popup-item--active {
  background: #fff1ef;
  color: #e64340;
  font-weight: 600;
}

.filter-form {
  margin-top: 22rpx;
}

.filter-field + .filter-field {
  margin-top: 18rpx;
}

.filter-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #666;
}

.filter-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f6f7fb;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #222;
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.filter-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.filter-btn--ghost {
  background: #f3f4f7;
  color: #59606d;
}

.filter-btn--primary {
  background: linear-gradient(135deg, #ff7e67 0%, #e64340 100%);
  color: #fff;
}
