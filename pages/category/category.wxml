<view class="find-page" style="padding-top:{{navHeight}}px">
  <!-- custom navigationBar -->
  <view class="find-nav" style="height:{{navHeight}}px;padding-top:{{navTop}}px">
    <view class="find-nav-inner" style="height:{{navHeight - navTop}}px">
      <view class="find-tabs-wrap" style="width:{{navTabWidth ? navTabWidth : 280}}px">
        <van-tabs active="{{circleActive}}" bind:change="onCircleChange" custom-class="find-tabs">
          <van-tab title="婚庆圈"></van-tab>
          <van-tab title="商城圈"></van-tab>
        </van-tabs>
      </view>
      <view
        class="find-add"
        style="right:{{navRightGap ? (navRightGap + 8) : 16}}px;top:0px;height:{{navHeight - navTop}}px"
        bindtap="onAddDiscover"
      >
        <van-icon name="plus" size="22" color="#666" />
      </view>
    </view>
  </view>

  <view class="find-filter">
    <view wx:if="{{circleActive === 0}}" class="find-filter-row">
      <view class="find-filter-item find-filter-item--category" bindtap="openFilterPopup" data-mode="category">
        <text class="find-filter-text">{{jobTypeName}}</text>
        <van-icon name="arrow-down" size="12" color="#666" />
      </view>
      <view class="find-filter-item {{orderActive !== null ? 'find-filter-item--active' : ''}}" bindtap="openFilterPopup" data-mode="sort">
        <text class="find-filter-text">{{sortLabel}}</text>
        <van-icon name="arrow-down" size="12" color="#666" />
      </view>
      <view class="find-filter-item {{areaName !== '全区域' ? 'find-filter-item--active' : ''}}" bindtap="openFilterPopup" data-mode="area">
        <text class="find-filter-text">{{areaName}}</text>
        <van-icon name="arrow-down" size="12" color="#666" />
      </view>
      <view class="find-filter-item {{jobTypeName !== '全部' ? 'find-filter-item--active' : ''}}" bindtap="openFilterPopup" data-mode="filter">
        <text class="find-filter-text">{{filterSummary}}</text>
        <van-icon name="filter-o" size="12" color="#666" />
      </view>
    </view>

    <view wx:else class="find-filter-row">
      <view class="find-filter-item {{orderActive !== null ? 'find-filter-item--active' : ''}}" bindtap="openFilterPopup" data-mode="sort">
        <text class="find-filter-text">{{sortLabel}}</text>
        <van-icon name="arrow-down" size="12" color="#666" />
      </view>
      <view class="find-filter-item {{areaName !== '全区域' ? 'find-filter-item--active' : ''}}" bindtap="openFilterPopup" data-mode="area">
        <text class="find-filter-text">{{areaName}}</text>
        <van-icon name="arrow-down" size="12" color="#666" />
      </view>
      <view class="find-filter-item" bindtap="openFilterPopup" data-mode="filter">
        <text class="find-filter-text">{{filterSummary}}</text>
        <van-icon name="filter-o" size="12" color="#666" />
      </view>
    </view>
  </view>

  <view class="discover-list">
    <view class="discover-card" wx:for="{{discoverList}}" wx:for-index="idx" wx:key="id" bindtap="onDiscoverTap" data-id="{{item.id}}">
      <view class="discover-head">
        <image class="discover-avatar" src="{{item.head || load_img}}" mode="aspectFill" lazy-load="true" binderror="onAvatarError" data-idx="{{idx}}" />
        <view class="discover-user">
          <view class="discover-name van-ellipsis">{{item.nickname}}</view>
          <view class="discover-sub van-ellipsis">
            <text wx:if="{{item.occupation}}">{{item.occupation}}</text>
            <text wx:if="{{item.theteam}}">{{item.theteam}}</text>
          </view>
        </view>
        <view class="discover-time van-ellipsis">{{item.create_ti}}</view>
      </view>

      <view class="discover-content">
        <mp-html content="{{item.content}}" loading-img="{{load_img}}" error-img="{{load_img_erro}}" />
      </view>

      <view class="discover-images discover-images--cols{{item._gridCols}}" wx:if="{{item.photoUrls && item.photoUrls.length > 0}}">
        <view
          class="discover-img-wrap"
          wx:for="{{item.photoUrls}}"
          wx:for-item="url"
          wx:for-index="pidx"
          wx:key="*this"
          style="width:{{item._gridCols === 1 ? gridSize1 : (item._gridCols === 2 ? gridSize2 : gridSize3)}}px;height:{{item._gridCols === 1 ? gridSize1 : (item._gridCols === 2 ? gridSize2 : gridSize3)}}px;"
        >
          <image
            class="discover-img"
            src="{{url || load_img}}"
            mode="aspectFill"
            lazy-load="true"
            binderror="onDiscoverImgError"
            data-idx="{{idx}}"
            data-pidx="{{pidx}}"
          />
        </view>
      </view>

      <view class="discover-meta">
        <view class="discover-meta-item">
          <van-icon name="eye-o" size="14" color="#999" />
          <text class="discover-meta-text">{{item.pv}}</text>
        </view>
        <view class="discover-meta-item">
          <van-icon name="comment-o" size="14" color="#999" />
          <text class="discover-meta-text">{{item.commentnum}}</text>
        </view>
        <view class="discover-meta-item">
          <van-icon name="good-job-o" size="14" color="#999" />
          <text class="discover-meta-text">{{item.zan}}</text>
        </view>
      </view>
    </view>

    <van-empty wx:if="{{loaded && (!discoverList || discoverList.length === 0)}}" image="../../images/zw.webp" description="暂无内容"></van-empty>
    <view wx:if="{{loading}}" class="discover-loading">加载中...</view>
    <view wx:if="{{noMore && discoverList && discoverList.length > 0}}" class="discover-nomore">没有更多了</view>
  </view>

  <van-popup show="{{jobPopupShow}}" position="bottom" round bind:close="closeJobPopup">
    <view class="job-popup">
      <view class="job-popup-title">选择职业</view>
      <van-cell-group>
        <van-cell
          wx:for="{{jobTypes}}"
          wx:key="occupationid"
          title="{{item.proname}}"
          clickable
          bind:click="selectJobType"
          data-id="{{item.occupationid}}"
          data-name="{{item.proname}}"
        />
      </van-cell-group>
    </view>
  </van-popup>

  <van-popup show="{{filterPopupShow}}" position="bottom" round bind:close="closeFilterPopup">
    <view class="job-popup">
      <view class="job-popup-title">
        <text wx:if="{{popupMode === 'sort'}}">综合排序</text>
        <text wx:elif="{{popupMode === 'area'}}">区域</text>
        <text wx:else>筛选</text>
      </view>

      <van-cell-group wx:if="{{popupMode === 'sort'}}">
        <van-cell
          wx:for="{{sortOptions}}"
          wx:key="key"
          title="{{item.label}}"
          clickable
          bind:click="selectSortOption"
          data-key="{{item.key}}"
        />
      </van-cell-group>

      <view wx:else class="find-filter-panel">
        <view class="find-filter-panel__text">当前发现页后台只接了分类和排序。区域已接入完整城市选择，更多高级筛选先保留安卓样式入口。</view>
        <view class="find-filter-panel__actions">
          <view class="find-filter-panel__btn find-filter-panel__btn--ghost" bindtap="closeFilterPopup">关闭</view>
          <view class="find-filter-panel__btn" bindtap="resetDiscoverFilter">重置分类</view>
        </view>
      </view>
    </view>
  </van-popup>
</view>
