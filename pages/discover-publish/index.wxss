page {
  min-height: 100%;
  background: #ffffff;
}

.publish-page {
  min-height: 100vh;
  background: #ffffff;
}

.publish-nav {
  position: relative;
  box-sizing: border-box;
  background: #ffffff;
}

.publish-nav-left,
.publish-nav-right {
  position: absolute;
  top: 0;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #666666;
}

.publish-nav-left {
  left: 0;
}

.publish-nav-right {
  right: 0;
}

.publish-nav-right--active {
  color: #e64340;
  font-weight: 600;
}

.publish-nav-title {
  margin: 0 160rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #222222;
}

.publish-divider {
  height: 2rpx;
  background: #f0f0f0;
}

.publish-content {
  padding: 24rpx 24rpx 148rpx;
}

.publish-textarea {
  width: 100%;
  min-height: 420rpx;
  font-size: 32rpx;
  line-height: 1.7;
  color: #222222;
}

.publish-placeholder {
  color: #b3b3b3;
}

.publish-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.publish-grid-item {
  position: relative;
  width: 216rpx;
  height: 216rpx;
  margin-right: 18rpx;
  margin-bottom: 18rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f6f8;
}

.publish-grid-item:nth-child(3n) {
  margin-right: 0;
}

.publish-image {
  width: 100%;
  height: 100%;
}

.publish-delete {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.48);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 40rpx;
  text-align: center;
}

.publish-toolbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 24rpx calc(env(safe-area-inset-bottom) + 10rpx);
  border-top: 2rpx solid #f0f0f0;
  background: #f9f9f9;
  box-sizing: content-box;
}

.publish-add-btn {
  display: flex;
  align-items: center;
  width: 100%;
  height: 96rpx;
}

.publish-add-text {
  margin-left: 14rpx;
  font-size: 28rpx;
  color: #8c8c8c;
}

.publish-add-count {
  margin-left: auto;
  font-size: 24rpx;
  color: #b3b3b3;
}
