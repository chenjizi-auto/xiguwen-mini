<view class="good-day-page">
  <view class="hero-card">
    <view class="hero-kicker">Lucky Day</view>
    <view class="hero-title">{{selectedDateText}}</view>
    <view class="hero-sub">{{lunarText}}</view>
  </view>

  <view class="toolbar-card">
    <view class="toolbar-top">
      <view class="toolbar-month">{{monthTitle}}</view>
      <picker mode="date" value="{{pickerDate}}" bindchange="onDatePick">
        <view class="toolbar-picker">切换日期</view>
      </picker>
    </view>
    <view class="toolbar-actions">
      <van-button size="small" plain type="primary" bind:click="onPrevMonth">上一月</van-button>
      <van-button size="small" plain type="primary" bind:click="onNextMonth">下一月</van-button>
    </view>
  </view>

  <view class="calendar-card">
    <view class="calendar-week">
      <view class="calendar-week__item">日</view>
      <view class="calendar-week__item">一</view>
      <view class="calendar-week__item">二</view>
      <view class="calendar-week__item">三</view>
      <view class="calendar-week__item">四</view>
      <view class="calendar-week__item">五</view>
      <view class="calendar-week__item">六</view>
    </view>
    <view class="calendar-grid">
      <view
        class="calendar-day {{item.disabled ? 'calendar-day--disabled' : ''}} {{item.checked ? 'calendar-day--checked' : ''}}"
        wx:for="{{calendarDays}}"
        wx:key="key"
        bindtap="onCalendarDayTap"
        data-day="{{item.day}}"
      >
        <text class="calendar-day__text {{item.isToday ? 'calendar-day__text--today' : ''}}">{{item.day}}</text>
      </view>
    </view>
  </view>

  <view class="state-error" wx:if="{{loadError}}">{{loadError}}</view>
  <view class="loading-text" wx:if="{{loading}}">加载中...</view>

  <block wx:if="{{luckDay}}">
    <view class="result-card">
      <view class="result-hd">
        <view class="result-title">宜</view>
      </view>
      <view class="result-body">{{luckDay.suit}}</view>
    </view>

    <view class="result-card result-card--danger">
      <view class="result-hd">
        <view class="result-title">忌</view>
      </view>
      <view class="result-body">{{luckDay.avoid}}</view>
    </view>
  </block>
</view>
