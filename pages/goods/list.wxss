page {
  background: #f7f8fa;
}
page,view,image,input {
  display: block;
  box-sizing: border-box;
}
.result-header {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.header {
  padding: 24rpx 24rpx 20rpx;
  background: #fff;
  display: flex;
  align-items: center;
}
.header .search {
  position: relative;
  flex: 1;
  height: 66rpx;
  background: #f7f8fa;
  border-radius: 33rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}
.header .search input {
  width: 100%;
  height: 100%;
  font-size: 26rpx;
  background: transparent;
  padding-left: 16rpx;
}
.header .search .search-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}
.header-cancel {
  margin-left: 24rpx;
  font-size: 28rpx;
  color: #ff4d4f;
  flex-shrink: 0;
}
.result-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx 18rpx;
}
.result-summary {
  min-width: 0;
}
.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
}
.result-count {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8c8c8c;
}
.result-actions {
  display: flex;
  align-items: center;
}
.search-submit {
  padding: 10rpx 22rpx;
  border-radius: 24rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  line-height: 32rpx;
}
.header .show-type,
.result-actions .show-type {
  width: 36rpx;
  height: 36rpx;
  margin-left: 20rpx;
}
.filters {
  height: 88rpx;
  background: #fff;
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid #f5f5f5;
}
.filters .item {
  line-height: 88rpx;
  position: relative;
  font-size: 26rpx;
  color: #666;
}
.filters .active {
  color:#fa1e26;
  font-weight: 600;
}
.filters .active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 14rpx;
  width: 28rpx;
  height: 6rpx;
  margin-left: -14rpx;
  border-radius: 6rpx;
  background: #fa1e26;
}
.list1 {
  margin: 16rpx;
  width: 718rpx;
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}
.list1 .img {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}
.list1 .goods-info {
  padding: 20rpx 28rpx 16rpx 24rpx;
  width: 100%;
}
.list1 .goods-info .title {
  color: #333;
  font-size: 30rpx;
}
.ellipsis {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  word-break: break-all;
}
.list1 .goods-info .price {
  color: #FF3B30;
  font-size: 34rpx;
  margin-top: 22rpx;
}
.list1 .goods-info .buy-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}
.list1 .goods-info .buy-info .num {
  font-size:24rpx;
  color:#999999;
}
.list1 .goods-info .buy-info .car {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 50rpx;
  height: 50rpx;
}
.list2-box {
  margin: 16rpx;
  width: 718rpx;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}
.list2 {
  margin: 16rpx 0;
  width: 350rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}
.list2 .img {
  width: 350rpx;
  height: 350rpx;
}
.list2 .goods-info {
  padding: 16rpx;
}
.list2 .goods-info .title {
  color: #333;
  font-size: 30rpx;
}
.list2 .goods-info .price {
  color: #FF3B30;
  font-size: 34rpx;
  margin-top: 18rpx;
}
.list2 .goods-info .buy-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
}
.list2 .goods-info .buy-info .num {
  font-size:24rpx;
  color:#999999;
}
.list2 .goods-info .buy-info .car {
  width: 50rpx;
  height: 50rpx;
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
}

.originalPrice {
  color: #aaa;
  text-decoration: line-through;
  margin-left: 20rpx;
  font-size: 26rpx;
}

.loading-box {
  padding: 120rpx 0 80rpx;
}

.list-loading-more {
  padding: 24rpx 0 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}
