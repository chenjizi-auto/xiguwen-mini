.cert-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f7f7f7;
}

.cert-card,
.upload-card {
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  overflow: hidden;
}

.cert-item {
  display: flex;
  align-items: center;
  min-height: 100rpx;
  padding: 0 28rpx;
}

.cert-item__label {
  width: 180rpx;
  color: #333;
  font-size: 30rpx;
}

.cert-item__input {
  flex: 1;
  min-width: 0;
  color: #333;
  font-size: 30rpx;
}

.cert-divider {
  height: 1rpx;
  margin-left: 28rpx;
  background: #f0f0f0;
}

.upload-group {
  margin-bottom: 44rpx;
}

.upload-title {
  padding: 8rpx 8rpx 20rpx;
  color: #999;
  font-size: 26rpx;
}

.upload-card {
  padding: 28rpx;
}

.upload-card__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.upload-card__title {
  color: #333;
  font-size: 30rpx;
  font-weight: 600;
}

.upload-card__hint {
  flex: 1;
  text-align: right;
  color: #999;
  font-size: 24rpx;
}

.upload-box {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 360rpx;
  border: 2rpx dashed #e5e5e5;
  border-radius: 20rpx;
  background: #fafafa;
}

.upload-box__placeholder {
  color: #999;
  font-size: 28rpx;
}

.upload-box__image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.upload-box__edit {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.62);
  color: #fff;
  font-size: 24rpx;
  line-height: 32rpx;
}

.cert-submit {
  margin-top: 40rpx;
}
