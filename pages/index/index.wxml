<block wx:if="{{rementuandui && rementuandui.length > 0}}">
  <scroll-view scroll-x="true">
    <view class="aaaaaaa">
      <view class="miaosha-container">
        <view class="miaosha-goods-list" wx:for="{{rementuandui}}" wx:key="adid" bindtap="toDetailsTap" data-id="{{item.id}}" data-supplytype="{{item.supplyType}}" data-yyid="{{item.yyId}}">
          <image src="{{item.wapimg}}" class="image" mode="aspectFill" lazy-load="true" />
          <view class="r">
            <view class="goods-title">{{item.title}}</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</block>

<block wx:if="{{remenhuodong}}">
  <van-divider custom-class="table-text" contentPosition="center">热门活动</van-divider>
  <view class="hunli-anli-container2">
    <van-grid column-num='2'>
      <van-grid-item use-slot>
        <image style="width: 100%; height: 200rpx;" mode="aspectFill" src="{{remenhuodong.rmhd1.wapimg}}" />
      </van-grid-item>
      <van-grid-item use-slot>
        <image style="width: 100%; height: 110px;" src="{{remenhuodong.rmhd2.wapimg}}" />
      </van-grid-item>
    </van-grid>
    <van-grid column-num='3'>
      <van-grid-item use-slot>
        <image style="width: 100%; height: 110px;" src="{{remenhuodong.rmhd3.wapimg}}" />
      </van-grid-item>
      <van-grid-item use-slot>
        <image style="width: 100%; height: 110px;" src="{{remenhuodong.rmhd4.wapimg}} " />
      </van-grid-item>
      <van-grid-item use-slot>
        <image style="width: 100%; height: 110px;" src="{{remenhuodong.rmhd5.wapimg}} " />
