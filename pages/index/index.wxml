<block wx:if="{{youlike}}">
  <van-divider custom-class="table-text" contentPosition="center">商家展示</van-divider>
  <view class="shop-short-container2">
    <view class="bbbbbb">
      <view class="shop_item_container">
        <view class="shop-item-list" wx:for="{{youlike}}" wx:key="id" bindtap="toDetailsTap" data-id="{{item.id}}" data-typpe="{{item.typpe}}" data-shopid="{{item.shopid}}">
          <view class="shop-host-item" wx:if="{{item.typee === '4'}}">
            <view class="shop_item_head">
              <van-image  round width="3rem" height="3rem" fit="cover" src="{{item.head}}" />
              <view class="shop_label_container">
                <view class="shop_name">{{item.nickname}}</view>
                <view class="shop_type">{{item.occupationid}}</view>
              </view>
              <view class="shop_focus_btn">
                <van-button plain hairline type="primary" size="mini">关注</van-button>
              </view>
            </view>
            <image src="{{item.shopimg}}" class="shop_cover" mode="aspectFill" lazy-load="true" />
            <view class="shop-item-title">{{item.shopname}}</view>
            <view class="shop-item-price">{{item.price}}</view>
            <view class="shop_bottom_line"></view>
          </view>
          <view class="shop-host-item" wx:if="{{item.typee === '3'}}">
            <view class="shop_item_head">
              <van-image round width="3rem" height="3rem" src="{{item.head}}" />
              <view class="shop_label_container">
                <view class="shop_name">{{item.nickname}}</view>
                <view class="shop_type">{{item.occupationid}}</view>
              </view>
              <view class="shop_focus_btn">
                <van-button plain hairline type="primary" size="mini">关注</van-button>
              </view>
            </view>
            <view class="shop-video-container">
              <!-- <video src="{{item.video_url}}" autoplay="false" loop="true" style='width:730rpx;height:300rpx;'></video> -->
              <image style="width: 50rpx; height: 50rpx; position: absolute; z-index: 100;left: 350rpx;top: 175rpx;" src="../../images/video_play.png" />
              <image src="{{item.cover}}" class="shop_cover" mode="aspectFill" lazy-load="true" />
            </view>
          
            <view class="shop-item-title">{{item.title}}</view>
            <view class="shop_bottom_line"></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</block>

</block>
<block wx:elif="{{activeIndex === 1}}">
  <view class="club-page">
    <view class="club-filter">
      <view class="club-filter-item" bindtap="openClubPopup" data-mode="type">
        <text class="club-filter-text">{{clubTypeName}}</text>
        <van-icon name="arrow-down" size="14" color="#666" />
      </view>
      <view class="club-filter-item" bindtap="openClubPopup" data-mode="sort">
        <text class="club-filter-text">{{clubSortName}}</text>
        <van-icon name="arrow-down" size="14" color="#666" />
      </view>
      <view class="club-filter-item" bindtap="openClubPopup" data-mode="area">
        <text class="club-filter-text">{{clubAreaName}}</text>
        <van-icon name="arrow-down" size="14" color="#666" />
      </view>
      <view class="club-filter-item" bindtap="openClubPopup" data-mode="filter">
        <text class="club-filter-text">筛选</text>
        <van-icon name="filter-o" size="14" color="#666" />
      </view>
    </view>

    <view class="club-list">
      <view class="club-item" wx:for="{{clubList}}" wx:key="id">
        <image class="club-item-img" src="{{item.logourl}}" mode="aspectFill" lazy-load="true" />
        <view class="club-item-body">
          <view class="club-item-title van-ellipsis">{{item.name}}</view>
          <view class="club-item-row">
            <text class="club-item-price">¥ {{item.minimumprice}}起</text>
            <text class="club-item-members">成员: {{item.membersnum}}</text>
            <text class="club-item-type van-ellipsis">{{item.type}}</text>
          </view>
          <view class="club-item-row2">
            <van-icon name="location-o" size="14" color="#999" />
            <text class="club-item-address van-ellipsis">{{item.address}}</text>
          </view>
        </view>
      </view>

      <van-empty wx:if="{{!clubLoading && (!clubList || clubList.length === 0)}}" image="../../images/zw.png" description="暂无社团"></van-empty>

      <view wx:if="{{clubLoading}}" class="club-loading">加载中...</view>
      <view wx:if="{{clubNoMore && clubList && clubList.length > 0}}" class="club-nomore">没有更多了</view>
    </view>

    <van-popup show="{{clubPopupShow}}" position="bottom" round bind:close="closeClubPopup">
      <view class="club-popup">
        <view class="club-popup-title">
          <text wx:if="{{clubPopupMode === 'type'}}">全部</text>
          <text wx:elif="{{clubPopupMode === 'sort'}}">综合排序</text>
          <text wx:elif="{{clubPopupMode === 'area'}}">全区域</text>
          <text wx:elif="{{clubPopupMode === 'filter'}}">筛选</text>
        </view>

        <block wx:if="{{clubPopupMode === 'type'}}">
          <van-cell-group>
            <van-cell wx:for="{{clubTypes}}" wx:key="occupationid" title="{{item.proname}}" clickable bind:click="selectClubType" data-id="{{item.occupationid}}" data-name="{{item.proname}}" />
          </van-cell-group>
        </block>

        <block wx:elif="{{clubPopupMode === 'sort'}}">
          <van-cell-group>
            <van-cell title="综合排序" clickable bind:click="selectClubSort" data-value="1" data-name="综合排序" />
            <van-cell title="默认" clickable bind:click="selectClubSort" data-value="" data-name="默认" />
          </van-cell-group>
        </block>

        <block wx:elif="{{clubPopupMode === 'area'}}">
          <van-empty image="search" description="小程序暂未接入区县列表，默认全区域"></van-empty>
        </block>

        <block wx:elif="{{clubPopupMode === 'filter'}}">
          <view class="club-popup-filter">
            <van-field
              label="最低价"
              type="number"
              placeholder="不限"
              value="{{clubMoneyMin}}"
              bind:change="onClubMoneyMinInput"
            />
            <van-field
              label="最高价"
              type="number"
              placeholder="不限"
              value="{{clubMoneyMax}}"
              bind:change="onClubMoneyMaxInput"
            />
            <view class="club-popup-actions">
              <van-button size="small" plain type="primary" bind:click="resetClubFilter">重置</van-button>
              <van-button size="small" type="primary" bind:click="confirmClubFilter">确定</van-button>
            </view>
          </view>
        </block>
      </view>
    </van-popup>
  </view>
</block>
<block wx:elif="{{activeIndex === 2}}">
  <view class="case-page">
    <view class="case-top">
      <view class="case-top-item" wx:for="{{caseTopTabs}}" wx:key="type" bindtap="onCaseTopTap" data-type="{{item.type}}">
        <van-icon name="{{item.icon}}" size="22" color="{{caseType === item.type ? '#ff5384' : '#666'}}" />
        <text class="case-top-text {{caseType === item.type ? 'case-top-text--active' : ''}}">{{item.text}}</text>
      </view>
    </view>

    <view class="case-list">
      <view class="case-card" wx:for="{{caseList}}" wx:key="id" bindtap="onCaseItemTap" data-id="{{item.id}}">
        <view class="case-card-head">
          <image class="case-avatar" src="{{item.head}}" mode="aspectFill" lazy-load="true" />
          <text class="case-name van-ellipsis">{{item.nickname}}</text>
          <view class="case-care">
            <van-icon name="{{item.afollow === 1 ? 'like' : 'like-o'}}" size="18" color="{{item.afollow === 1 ? '#ff5384' : '#999'}}" />
          </view>
        </view>

        <image class="case-cover" src="{{item.weddingcover}}" mode="aspectFill" lazy-load="true" />

        <view class="case-title van-ellipsis">{{item.title}}</view>
        <view class="case-price">¥ {{item.weddingexpenses}}</view>
        <view class="case-desc van-multi-ellipsis--l2">{{item.weddingdescribe}}</view>

        <view class="case-meta">
          <view class="case-meta-item">
            <van-icon name="eye-o" size="14" color="#999" />
            <text class="case-meta-text">{{item.clicked}}</text>
          </view>
          <view class="case-meta-item">
            <van-icon name="good-job-o" size="14" color="#999" />
            <text class="case-meta-text">{{item.goodscore}}</text>
          </view>
          <view class="case-meta-item">
            <van-icon name="comment-o" size="14" color="#999" />
            <text class="case-meta-text">{{item.commented}}</text>
          </view>
        </view>
      </view>

      <van-empty wx:if="{{!caseLoading && (!caseList || caseList.length === 0)}}" image="../../images/zw.png" description="暂无案例"></van-empty>
      <view wx:if="{{caseLoading}}" class="case-loading">加载中...</view>
      <view wx:if="{{caseNoMore && caseList && caseList.length > 0}}" class="case-nomore">没有更多了</view>
    </view>
  </view>
</block>
