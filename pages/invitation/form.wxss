.invitation-form-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7fb;
}

.form-card {
  padding: 30rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 32rpx rgba(18, 31, 53, 0.06);
}

.template-brief {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.template-thumb {
  width: 140rpx;
  height: 180rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
}

.template-meta {
  flex: 1;
  min-width: 0;
}

.template-name,
.field-label {
  color: #231f20;
  font-size: 28rpx;
  font-weight: 700;
}

.template-tip {
  margin-top: 10rpx;
  color: #8d826b;
  font-size: 24rpx;
}

.field-group + .field-group {
  margin-top: 24rpx;
}

.field-input,
.picker-input,
.field-textarea {
  width: 100%;
  margin-top: 12rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f7f8fa;
  color: #222;
  font-size: 28rpx;
  box-sizing: border-box;
}

.field-textarea {
  min-height: 220rpx;
}
