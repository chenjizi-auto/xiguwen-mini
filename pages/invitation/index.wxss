.invitation-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(212, 173, 96, 0.14), transparent 30%),
    linear-gradient(180deg, #fffaf2 0%, #f6f7fb 300rpx, #f6f7fb 100%);
}

.hero-card,
.toolbar-card,
.invite-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 32rpx rgba(18, 31, 53, 0.06);
}

.hero-kicker {
  color: #b5842d;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  text-transform: uppercase;
}

.hero-title {
  margin-top: 12rpx;
  color: #2c2519;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-desc {
  margin-top: 14rpx;
  color: #8d826b;
  font-size: 24rpx;
  line-height: 1.8;
}

.toolbar-card,
.invite-card,
.invite-actions {
  display: flex;
}

.toolbar-card,
.invite-card {
  margin-top: 20rpx;
  align-items: center;
  justify-content: space-between;
}

.toolbar-title,
.invite-title {
  color: #2c2519;
  font-size: 30rpx;
  font-weight: 700;
}

.card-list {
  margin-top: 20rpx;
}

.invite-card {
  gap: 20rpx;
  align-items: stretch;
}

.invite-cover {
  width: 180rpx;
  height: 240rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.invite-main {
  flex: 1;
  min-width: 0;
}

.invite-sub,
.loading-text,
.state-error {
  margin-top: 12rpx;
  color: #8d826b;
  font-size: 24rpx;
}

.invite-actions {
  gap: 12rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.invite-btn {
  min-width: 144rpx !important;
}

.loading-text,
.state-error {
  margin-top: 32rpx;
  text-align: center;
}
