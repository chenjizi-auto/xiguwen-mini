.template-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7fb;
}

.type-scroll {
  white-space: nowrap;
}

.type-row {
  display: flex;
  gap: 16rpx;
}

.type-chip {
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #7b7f87;
  font-size: 26rpx;
  box-shadow: 0 8rpx 24rpx rgba(18, 31, 53, 0.04);
  flex-shrink: 0;
}

.type-chip--active {
  background: #c79842;
  color: #fff;
  font-weight: 700;
}

.template-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 24rpx;
}

.template-card {
  padding: 20rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 32rpx rgba(18, 31, 53, 0.06);
}

.template-cover {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
}

.template-title {
  margin-top: 16rpx;
  color: #2c2519;
  font-size: 28rpx;
  font-weight: 700;
}

.template-sub,
.loading-text,
.state-error {
  margin-top: 10rpx;
  color: #8d826b;
  font-size: 24rpx;
}

.template-btn {
  margin-top: 18rpx;
}

.loading-text,
.state-error {
  text-align: center;
}
