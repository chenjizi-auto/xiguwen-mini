.login-page {
  min-height: 100vh;
  background: #ffffff;
}

.login-nav {
  position: relative;
  box-sizing: border-box;
}

.login-back {
  position: absolute;
  left: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
}

.login-back-icon {
  width: 34rpx;
  height: 34rpx;
}

.login-title {
  margin: 0 140rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #222222;
}

.login-content {
  padding: 90rpx 48rpx 96rpx;
}

.login-logo {
  display: block;
  width: 168rpx;
  height: 168rpx;
  margin: 80rpx auto 40rpx;
  border-radius: 84rpx;
}

.login-slogan {
  margin-bottom: 260rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #222222;
}

.login-form {
  margin: 120rpx 0 70rpx;
}

.login-input-row {
  display: flex;
  align-items: center;
  min-height: 108rpx;
}

.login-country {
  margin-right: 26rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.login-input {
  flex: 1;
  height: 108rpx;
  font-size: 34rpx;
  color: #1f1f1f;
}

.login-input--full {
  width: 100%;
}

.login-input-placeholder {
  color: #b3b3b3;
}

.login-input-line {
  height: 2rpx;
  background: #ececec;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border: 0;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.login-btn::after {
  border: 0;
}

.login-btn--primary {
  margin-top: 24rpx;
  background: #ffd400;
  color: #1f1f1f;
}

.login-btn--ghost {
  margin-top: 24rpx;
  background: #f2f2f2;
  color: #1f1f1f;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  margin-top: 64rpx;
}

.agreement-icon {
  flex: 0 0 34rpx;
  width: 34rpx;
  height: 34rpx;
  margin: 6rpx 18rpx 0 0;
  border: 2rpx solid #cdcdcd;
  border-radius: 50%;
  box-sizing: border-box;
}

.agreement-icon--checked {
  display: flex;
  align-items: center;
  justify-content: center;
  border-color: #ffd400;
  background: #ffd400;
}

.agreement-check {
  color: #1f1f1f;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.agreement-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: #9b9b9b;
}

.agreement-link {
  color: #4b4b4b;
}

.agreement-mask {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  background: rgba(0, 0, 0, 0.38);
  box-sizing: border-box;
}

.agreement-dialog {
  width: 100%;
  overflow: hidden;
  background: #ffffff;
  border-radius: 26rpx;
}

.agreement-dialog-title {
  padding: 54rpx 48rpx 24rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.agreement-dialog-content {
  padding: 0 48rpx 44rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #666666;
}

.agreement-dialog-actions {
  display: flex;
  border-top: 2rpx solid #f0f0f0;
}

.agreement-dialog-btn {
  flex: 1;
  height: 104rpx;
  line-height: 104rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.agreement-dialog-btn--plain {
  color: #2d2d2d;
  background: #ffffff;
}

.agreement-dialog-btn--primary {
  color: #1f1f1f;
  background: #ffd400;
}
