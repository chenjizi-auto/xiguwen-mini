@import "/pages/my/mine-atlas-detail/index.wxss";

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.info-label {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}

.info-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #222;
}
