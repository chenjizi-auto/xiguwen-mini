.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.hero-kicker {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #e64340;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  line-height: 56rpx;
  font-weight: 700;
  color: #222;
}

.hero-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #666;
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.preset-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.preset-item {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 22rpx;
  font-size: 28rpx;
  color: #e64340;
  background: #fff1f0;
}

.preset-item--active {
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}

.input,
.textarea {
  width: 100%;
  border-radius: 24rpx;
  background: #f7f8fa;
  font-size: 28rpx;
  color: #222;
}

.input {
  height: 88rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 180rpx;
  margin-top: 18rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.submit-wrap {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.submit-btn {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}
