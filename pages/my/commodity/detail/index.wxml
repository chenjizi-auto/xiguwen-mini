<view class="atlas-detail-page">
  <block wx:if="{{loading && !detail}}">
    <view class="atlas-detail-loading">加载中...</view>
  </block>

  <block wx:elif="{{detail}}">
    <scroll-view scroll-y class="atlas-detail-scroll">
      <view class="atlas-detail-card">
        <image class="atlas-detail-cover" src="{{detail.cover || defaultCover}}" mode="aspectFill" bindtap="previewImage" data-url="{{detail.cover}}" />

        <view class="atlas-detail-head">
          <view class="atlas-detail-title">{{detail.title}}</view>
          <view class="atlas-detail-status">{{detail.statusLabel}}</view>
        </view>

        <view class="atlas-detail-section">
          <view class="info-row"><text class="info-label">一级类目</text><text class="info-value">{{detail.type1Text}}</text></view>
          <view class="info-row"><text class="info-label">二级类目</text><text class="info-value">{{detail.type2Text}}</text></view>
          <view class="info-row"><text class="info-label">商品价格</text><text class="info-value">¥ {{detail.priceText}}</text></view>
          <view class="info-row"><text class="info-label">商品单位</text><text class="info-value">{{detail.unitText}}</text></view>
          <view class="info-row"><text class="info-label">抵扣券</text><text class="info-value">¥ {{detail.couponsText}}</text></view>
          <view class="info-row"><text class="info-label">排序</text><text class="info-value">{{detail.weightText}}</text></view>
          <view class="info-row"><text class="info-label">运费模板</text><text class="info-value">{{detail.freightText}}</text></view>
          <view class="info-row"><text class="info-label">商品地区</text><text class="info-value">{{detail.areaText}}</text></view>
        </view>

        <view class="atlas-detail-section">
          <view class="atlas-detail-section-title">商品图片</view>
          <view wx:if="{{detail.photos.length}}" class="atlas-detail-grid">
            <image
              wx:for="{{detail.photos}}"
              wx:key="*this"
              class="atlas-detail-grid-item"
              src="{{item}}"
              mode="aspectFill"
              bindtap="previewImage"
              data-url="{{item}}"
            />
          </view>
          <view wx:else class="atlas-detail-empty">暂无图片</view>
        </view>
      </view>
      <view class="atlas-detail-safe"></view>
    </scroll-view>

    <view class="atlas-detail-actions">
      <view wx:if="{{actionConfig.canEdit}}" class="atlas-detail-action atlas-detail-action--ghost" bindtap="goEdit">编辑</view>
      <view wx:if="{{actionConfig.canDelete}}" class="atlas-detail-action atlas-detail-action--ghost" bindtap="onDelete">删除</view>
      <view wx:if="{{actionConfig.primaryText}}" class="atlas-detail-action atlas-detail-action--primary" bindtap="onPrimaryAction">
        {{actionConfig.primaryText}}
      </view>
    </view>
  </block>
</view>
