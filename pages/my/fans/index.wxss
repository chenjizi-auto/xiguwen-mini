.fans-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.fans-summary {
  height: 60rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  background: #f0f0f0;
}

.fans-list {
  background: #fff;
}

.fans-item {
  display: flex;
  align-items: center;
  min-height: 160rpx;
  padding: 0 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.fans-item:last-child {
  border-bottom: 0;
}

.fans-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f2f3f5;
  flex-shrink: 0;
}

.fans-main {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.fans-headline {
  display: flex;
  align-items: baseline;
}

.fans-name {
  max-width: 320rpx;
  font-size: 32rpx;
  line-height: 44rpx;
  color: #222;
  font-weight: 600;
}

.fans-job {
  max-width: 220rpx;
  margin-left: 16rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #999;
}

.fans-region {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #999;
}

.fans-loading {
  padding: 28rpx 0 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}
