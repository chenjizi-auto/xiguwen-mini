.mine-page {
  height: 100vh;
  background: #f7f8fa;
}

.mine-top {
  position: relative;
  height: 292rpx;
  background: #fff;
  overflow: hidden;
}

.mine-top-bg {
  width: 100%;
  height: 292rpx;
}

.mine-top-arc {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -62rpx;
  height: 124rpx;
  background: #fff;
  border-top-left-radius: 124rpx;
  border-top-right-radius: 124rpx;
  z-index: 1;
}

.mine-top-bar {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  z-index: 3;
}

.mine-top-bar-inner {
  position: relative;
}

.mine-setting {
  position: absolute;
  right: 24rpx;
  top: 0;
  width: 88rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.mine-setting-icon {
  width: 44rpx;
  height: 44rpx;
}

.mine-avatar-card {
  position: absolute;
  left: 50%;
  bottom: 18rpx;
  transform: translateX(-50%);
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: rgba(255, 255, 255, 0.92);
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.mine-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #f2f3f5;
}

.mine-profile {
  background: #fff;
  padding: 10rpx 24rpx 14rpx;
}

.mine-name {
  text-align: center;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
  color: #333;
}

.mine-login-tip {
  margin-top: 6rpx;
  text-align: center;
  font-size: 24rpx;
  color: #e64340;
}

.mine-team {
  text-align: center;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #999;
  min-height: 34rpx;
}

.mine-stats {
  margin-top: 2rpx;
  background: #fff;
  padding: 20rpx 24rpx;
  display: flex;
}

.mine-stat-item {
  flex: 1;
  text-align: center;
  min-width: 0;
}

.mine-stat-num {
  font-size: 28rpx;
  line-height: 40rpx;
  color: #333;
  font-weight: 500;
}

.mine-stat-num--red {
  color: #e64340;
}

.mine-stat-label {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #333;
}

.mine-section {
  background: #fff;
  overflow: hidden;
}

.mine-section--spaced {
  margin-top: 16rpx;
}

.mine-section-hd {
  height: 76rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
}

.mine-section-title {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  color: #333;
}

.mine-grid-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 112rpx;
  padding: 10rpx 0 8rpx;
}

.mine-grid-icon {
  width: 38rpx;
  height: 38rpx;
}

.mine-grid-text {
  margin-top: 4rpx;
  font-size: 18rpx;
  line-height: 24rpx;
  color: #666;
}

.mine-grid-badge {
  position: absolute;
  right: 24rpx;
  top: 12rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 16rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
}

.mine-menu {
  margin-top: 16rpx;
  background: #fff;
}

.mine-menu-item {
  min-height: 92rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mine-menu-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.mine-menu-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.mine-menu-text {
  font-size: 28rpx;
  line-height: 40rpx;
  color: #333;
}

.mine-menu-arrow {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.mine-menu-divider {
  height: 1rpx;
  margin-left: 88rpx;
  background: #ededed;
}

.mine-safe-bottom {
  height: 48rpx;
}
