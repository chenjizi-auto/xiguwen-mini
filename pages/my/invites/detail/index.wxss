.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.content {
  padding: 24rpx;
}

.state-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #d4380d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.date-card,
.list-card {
  margin-bottom: 20rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.date-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.date-nav {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #e64340;
}

.date-center {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 600;
  color: #222;
}

.list-title {
  padding: 26rpx 28rpx 8rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.invite-row {
  padding: 24rpx 28rpx;
  border-top: 1rpx solid #f3f4f6;
}

.invite-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.invite-mobile {
  font-size: 28rpx;
  line-height: 40rpx;
  color: #222;
}

.invite-index {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 28rpx;
  color: #e64340;
  background: rgba(230, 67, 64, 0.08);
}

.invite-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8c8f96;
}

.loading-text {
  padding: 18rpx 0 26rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}
