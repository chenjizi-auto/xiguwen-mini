<view class="page">
  <view class="hero">
    <view class="hero-title">我的邀请</view>
    <view class="hero-actions">
      <view class="detail-btn" bindtap="openDetails">明细</view>
      <button class="share-btn" open-type="share">邀请好友</button>
    </view>
  </view>

  <view class="content">
    <view class="state-error" wx:if="{{errorText}}">{{errorText}}</view>

    <view class="date-card">
      <view class="date-nav" bindtap="onPrevDay">上一天</view>
      <picker mode="date" value="{{dateValue}}" bindchange="onDateChange">
        <view class="date-center">{{dateText}}</view>
      </picker>
      <view class="date-nav" bindtap="onNextDay">下一天</view>
    </view>

    <view class="summary-card">
      <view class="summary-item">
        <view class="summary-num">{{num}}</view>
        <view class="summary-label">邀请人数</view>
      </view>
      <view class="summary-item">
        <view class="summary-num summary-num--money">{{money}}</view>
        <view class="summary-label">邀请收益(元)</view>
      </view>
    </view>

    <block wx:if="{{list.length}}">
      <view class="list-card">
        <view class="list-title">邀请明细</view>
        <view class="invite-row" wx:for="{{list}}" wx:key="index">
          <view class="invite-mobile">{{item.mobile || '--'}}</view>
          <view class="invite-time">{{item.created_at || '--'}}</view>
        </view>
      </view>
    </block>

    <van-empty wx:if="{{!loading && !list.length && !errorText}}" image="/images/empty/nodata.webp" description="当日暂无邀请明细" />
    <view class="loading-text" wx:if="{{loading}}">加载中...</view>
  </view>
</view>
