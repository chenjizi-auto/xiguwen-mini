.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.hero {
  padding: 32rpx 24rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-title {
  flex: 1;
  font-size: 42rpx;
  line-height: 56rpx;
  font-weight: 700;
  color: #222;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-btn {
  padding: 0 24rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #e64340;
  background: rgba(230, 67, 64, 0.1);
}

.share-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}

.share-btn::after {
  border: 0;
}

.content {
  padding: 0 24rpx 32rpx;
}

.state-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #d4380d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.date-card,
.summary-card,
.list-card {
  margin-bottom: 20rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.date-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.date-nav {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #e64340;
}

.date-center {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 600;
  color: #222;
}

.summary-card {
  display: flex;
}

.summary-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 20rpx;
}

.summary-num {
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 700;
  color: #222;
}

.summary-num--money {
  color: #e64340;
}

.summary-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}

.list-title {
  padding: 26rpx 28rpx 8rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.invite-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 28rpx;
  border-top: 1rpx solid #f3f4f6;
}

.invite-mobile {
  font-size: 28rpx;
  line-height: 40rpx;
  color: #222;
}

.invite-time {
  margin-left: 20rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8c8f96;
}

.loading-text {
  padding: 18rpx 0 26rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}
