.atlas-detail-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(255, 120, 150, 0.16), transparent 30%),
    linear-gradient(180deg, #fff9fb 0%, #f5f5f7 100%);
}

.atlas-detail-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.atlas-detail-loading {
  padding-top: 220rpx;
  text-align: center;
  color: #8b7a81;
  font-size: 28rpx;
}

.atlas-detail-card {
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 20rpx 48rpx rgba(34, 24, 28, 0.06);
}

.atlas-detail-cover {
  width: 100%;
  height: 420rpx;
  border-radius: 24rpx;
  background: #f3f3f3;
}

.atlas-detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
}

.atlas-detail-title {
  flex: 1;
  color: #22181c;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.5;
}

.atlas-detail-status {
  max-width: 240rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 91, 134, 0.1);
  color: #ff5b86;
  font-size: 22rpx;
  text-align: center;
}

.atlas-detail-meta {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.atlas-detail-meta-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fff6f8;
}

.atlas-detail-meta-label {
  display: block;
  color: #a18f97;
  font-size: 22rpx;
}

.atlas-detail-meta-value {
  display: block;
  margin-top: 10rpx;
  color: #33272b;
  font-size: 28rpx;
  line-height: 1.5;
}

.atlas-detail-section {
  margin-top: 28rpx;
}

.atlas-detail-section-title {
  color: #22181c;
  font-size: 30rpx;
  font-weight: 600;
}

.atlas-detail-section-text {
  margin-top: 14rpx;
  color: #5f5056;
  font-size: 28rpx;
  line-height: 1.8;
  word-break: break-all;
}

.atlas-detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.atlas-detail-grid-item {
  width: calc((100% - 32rpx) / 3);
  height: 210rpx;
  border-radius: 18rpx;
  background: #f4f4f4;
}

.atlas-detail-empty {
  margin-top: 18rpx;
  color: #9f8e95;
  font-size: 26rpx;
}

.atlas-detail-safe {
  height: 140rpx;
}

.atlas-detail-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 28rpx rgba(34, 24, 28, 0.04);
  backdrop-filter: blur(12rpx);
}

.atlas-detail-action {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 84rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.atlas-detail-action--ghost {
  border: 2rpx solid #f1d6df;
  color: #7b616b;
  background: #fff;
}

.atlas-detail-action--primary {
  color: #fff;
  background: linear-gradient(135deg, #ff7b9b, #ff5b86);
}
