<scroll-view scroll-y class="atlas-edit-page">
  <view class="atlas-edit-card">
    <view class="atlas-edit-title">{{pageTitle}}</view>
    <view class="atlas-edit-sub">封面、描述和图片内容会一起提交到图册管理</view>

    <view class="atlas-edit-section">
      <view class="atlas-edit-label">图册名称</view>
      <input
        class="atlas-edit-input"
        value="{{name}}"
        maxlength="30"
        placeholder="请输入图册名称"
        bindinput="onNameInput"
      />
    </view>

    <view class="atlas-edit-section">
      <view class="atlas-edit-label">排序</view>
      <input
        class="atlas-edit-input"
        value="{{weight}}"
        type="digit"
        maxlength="6"
        placeholder="请输入排序值"
        bindinput="onWeightInput"
      />
    </view>

    <view class="atlas-edit-section">
      <view class="atlas-edit-label">图册描述</view>
      <textarea
        class="atlas-edit-textarea"
        value="{{description}}"
        maxlength="300"
        placeholder="请输入图册描述"
        bindinput="onDescriptionInput"
      />
      <view class="atlas-edit-counter">{{description.length}}/300</view>
    </view>

    <view class="atlas-edit-section">
      <view class="atlas-edit-row">
        <view class="atlas-edit-label">图册封面</view>
        <view class="atlas-edit-tip">必填</view>
      </view>

      <block wx:if="{{cover}}">
        <view class="atlas-edit-cover-wrap">
          <image class="atlas-edit-cover" src="{{cover || defaultCover}}" mode="aspectFill" bindtap="previewCover" />
          <view class="atlas-edit-remove" bindtap="removeCover">删除</view>
        </view>
      </block>
      <view wx:else class="atlas-edit-picker" bindtap="chooseCover">
        <text class="atlas-edit-picker-plus">+</text>
        <text class="atlas-edit-picker-text">选择封面</text>
      </view>
    </view>

    <view class="atlas-edit-section">
      <view class="atlas-edit-row">
        <view class="atlas-edit-label">图册图片</view>
        <view class="atlas-edit-tip">{{photoList.length}}/{{maxPhotoCount}}</view>
      </view>

      <view class="atlas-edit-grid">
        <view
          wx:for="{{photoList}}"
          wx:key="*this"
          class="atlas-edit-grid-item atlas-edit-grid-item--image"
        >
          <image class="atlas-edit-grid-image" src="{{item}}" mode="aspectFill" bindtap="previewPhoto" data-url="{{item}}" />
          <view class="atlas-edit-grid-remove" bindtap="removePhoto" data-index="{{index}}">×</view>
        </view>

        <view
          wx:if="{{photoList.length < maxPhotoCount}}"
          class="atlas-edit-grid-item atlas-edit-grid-item--picker"
          bindtap="choosePhotos"
        >
          <text class="atlas-edit-picker-plus">+</text>
          <text class="atlas-edit-grid-text">添加图片</text>
        </view>
      </view>
    </view>
  </view>

  <view class="atlas-edit-safe"></view>

  <view class="atlas-edit-actions">
    <view class="atlas-edit-submit" bindtap="onSave">{{saving ? '保存中...' : '保存图册'}}</view>
  </view>
</scroll-view>
