.atlas-page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 132, 166, 0.14), transparent 34%),
    linear-gradient(180deg, #fff8fa 0%, #fff 28%, #f7f7f9 100%);
  box-sizing: border-box;
}

.atlas-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(223, 98, 132, 0.08);
}

.atlas-toolbar-copy {
  min-width: 0;
  flex: 1;
  padding-right: 20rpx;
}

.atlas-toolbar-title {
  color: #22181c;
  font-size: 34rpx;
  font-weight: 600;
}

.atlas-toolbar-sub {
  margin-top: 8rpx;
  color: #8b7a81;
  font-size: 24rpx;
}

.atlas-toolbar-action {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7b9b, #ff5b86);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.atlas-tabs {
  display: flex;
  align-items: stretch;
  margin-top: 20rpx;
  padding: 8rpx 12rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(29, 23, 26, 0.05);
}

.atlas-tab {
  position: relative;
  flex: 1;
  padding: 18rpx 0 14rpx;
  text-align: center;
}

.atlas-tab-text {
  color: #8c7e84;
  font-size: 28rpx;
}

.atlas-tab-line {
  width: 44rpx;
  height: 6rpx;
  margin: 12rpx auto 0;
  border-radius: 999rpx;
  background: transparent;
}

.atlas-tab--active .atlas-tab-text {
  color: #ff5b86;
  font-weight: 600;
}

.atlas-tab--active .atlas-tab-line {
  background: #ff5b86;
}

.atlas-list {
  margin-top: 20rpx;
}

.atlas-card {
  display: flex;
  align-items: stretch;
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(34, 24, 28, 0.06);
}

.atlas-card-cover {
  width: 176rpx;
  height: 176rpx;
  flex-shrink: 0;
  border-radius: 22rpx;
  background: #f2f2f2;
}

.atlas-card-body {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  justify-content: space-between;
  padding-left: 22rpx;
}

.atlas-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.atlas-card-title {
  min-width: 0;
  color: #22181c;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.atlas-card-status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.atlas-card-status--pending {
  background: rgba(255, 183, 77, 0.14);
  color: #c97a00;
}

.atlas-card-status--success {
  background: rgba(76, 175, 80, 0.12);
  color: #2d8e3e;
}

.atlas-card-status--warning {
  background: rgba(255, 91, 134, 0.1);
  color: #ff5b86;
}

.atlas-card-status--danger {
  background: rgba(233, 83, 83, 0.12);
  color: #d94141;
}

.atlas-card-status--draft {
  background: rgba(102, 102, 102, 0.1);
  color: #666;
}

.atlas-card-desc {
  margin-top: 14rpx;
  color: #6d5c63;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

.atlas-card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  color: #aa98a0;
  font-size: 22rpx;
}

.atlas-empty {
  padding: 120rpx 0;
  text-align: center;
  color: #8b7a81;
  font-size: 28rpx;
}

.atlas-empty--loading {
  padding-top: 180rpx;
}

.atlas-loadmore {
  padding: 10rpx 0 28rpx;
  text-align: center;
  color: #8b7a81;
  font-size: 24rpx;
}

.atlas-loadmore--done {
  color: #b5a5ac;
}
