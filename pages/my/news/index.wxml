<view class="page">
  <van-sticky>
    <view class="hero">
      <view class="hero-kicker">婚礼新闻</view>
      <view class="hero-title">{{tabs[tabIndex].label}}</view>
      <view class="hero-desc">点击列表可查看完整内容，下拉可刷新，滑到底部继续加载。</view>
    </view>
    <van-tabs
      active="{{tabIndex}}"
      bind:change="onTabChange"
      swipeable="{{false}}"
      animated="{{false}}"
      color="#e64340"
      line-width="40rpx"
    >
      <van-tab wx:for="{{tabs}}" wx:key="index" title="{{item.label}}" />
    </van-tabs>
  </van-sticky>

  <view class="content">
    <view class="state-error" wx:if="{{errorText}}">{{errorText}}</view>

    <block wx:if="{{list.length}}">
      <view class="news-card" wx:for="{{list}}" wx:key="id" data-index="{{index}}" bindtap="onCardTap">
        <image class="news-cover" src="{{item.image}}" mode="aspectFill" />
        <view class="news-body">
          <view class="news-title van-multi-ellipsis--l2">{{item.title}}</view>
          <view class="news-desc van-multi-ellipsis--l2">{{item.desc || '点击查看详情内容'}}</view>
          <view class="news-meta">
            <view class="news-time">{{item.timeText}}</view>
            <view class="news-arrow">查看详情</view>
          </view>
        </view>
      </view>
    </block>

    <van-empty
      wx:if="{{!loading && !list.length && !errorText}}"
      image="/images/empty/nodata.webp"
      description="{{tabs[tabIndex].label}}暂无内容"
    />

    <view class="loading-text" wx:if="{{loading}}">加载中...</view>
    <view class="loading-text" wx:if="{{!loading && finished && list.length}}">没有更多了</view>
  </view>
</view>
