.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.title {
  flex: 1;
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 700;
  color: #222;
}

.status {
  flex-shrink: 0;
  align-self: flex-start;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #e64340;
  background: rgba(230, 67, 64, 0.08);
}

.price-row {
  margin-top: 18rpx;
}

.price {
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 700;
  color: #e64340;
}

.meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.photo-item {
  width: 100%;
  height: 200rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  gap: 16rpx;
}

.ghost-btn,
.primary-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.ghost-btn {
  color: #e64340;
  background: rgba(230, 67, 64, 0.1);
}

.primary-btn {
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}

.loading-text {
  padding: 120rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #8c8f96;
}
