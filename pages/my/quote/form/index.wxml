<view class="page">
  <view class="loading-text" wx:if="{{loading}}">加载中...</view>
  <block wx:else>
    <view class="card">
      <view class="form-row">
        <view class="form-label">报价名称</view>
        <input class="form-input" value="{{form.name}}" data-key="name" bindinput="onInput" placeholder="请输入名称" />
      </view>
      <view class="form-row">
        <view class="form-label">报价价格</view>
        <input class="form-input" value="{{form.price}}" data-key="price" bindinput="onInput" placeholder="请输入价格" />
      </view>
      <view class="form-row">
        <view class="form-label">定金金额</view>
        <input class="form-input" value="{{form.temporarypay}}" data-key="temporarypay" bindinput="onInput" placeholder="请输入定金" />
      </view>
      <view class="form-row">
        <view class="form-label">现金券抵扣</view>
        <input class="form-input" value="{{form.deductible}}" data-key="deductible" bindinput="onInput" placeholder="请输入折扣金额" />
      </view>
      <view class="form-row">
        <view class="form-label">报价排序</view>
        <input class="form-input" value="{{form.weigh}}" data-key="weigh" bindinput="onInput" placeholder="请输入排序" />
      </view>
    </view>

    <view class="card">
      <view class="section-title">备注</view>
      <textarea class="textarea" value="{{form.content}}" data-key="content" bindinput="onInput" maxlength="500" placeholder="请输入备注（选填）" />
    </view>

    <view class="card">
      <view class="section-head">
        <view class="section-title">报价图片</view>
        <view class="section-action" bindtap="choosePhotos">添加图片</view>
      </view>
      <view wx:if="{{photos.length}}" class="photo-grid">
        <view wx:for="{{photos}}" wx:key="index" class="photo-wrap">
          <image class="photo-item" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="previewPhoto" />
          <view class="photo-remove" data-index="{{index}}" bindtap="removePhoto">删除</view>
        </view>
      </view>
      <van-empty wx:else image="/images/empty/nodata.webp" description="暂无报价图片" />
    </view>

    <view class="actions">
      <view class="action-btn {{saving ? 'action-btn--disabled' : ''}}" bindtap="onSave">{{saving ? '保存中...' : '保存'}}</view>
    </view>
  </block>
</view>
