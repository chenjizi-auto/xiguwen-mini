<view class="page">
  <van-sticky>
    <view class="hero">
      <view>
        <view class="hero-kicker">发布报价</view>
        <view class="hero-title">我的报价</view>
      </view>
      <view class="hero-add" bindtap="goAdd">新增报价</view>
    </view>
    <van-tabs active="{{tabIndex}}" bind:change="onTabChange" color="#e64340" line-width="40rpx">
      <van-tab wx:for="{{tabs}}" wx:key="state" title="{{item.label}}" />
    </van-tabs>
  </van-sticky>

  <view class="content">
    <view class="state-error" wx:if="{{errorText}}">{{errorText}}</view>

    <view class="quote-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="onCardTap">
      <image class="quote-cover" src="{{item.cover}}" mode="aspectFill" />
      <view class="quote-body">
        <view class="quote-head">
          <view class="quote-title van-multi-ellipsis--l2">{{item.title}}</view>
          <view class="quote-status">{{item.statusText}}</view>
        </view>
        <view class="quote-price">{{item.priceText}}</view>
        <view class="quote-deductible" wx:if="{{item.deductibleText}}">{{item.deductibleText}}</view>
      </view>
    </view>

    <van-empty wx:if="{{!loading && !list.length && !errorText}}" image="/images/empty/nodata.webp" description="{{tabs[tabIndex].label}}暂无报价" />
    <view class="loading-text" wx:if="{{loading}}">加载中...</view>
  </view>
</view>
