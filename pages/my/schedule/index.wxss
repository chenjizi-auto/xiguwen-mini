.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.hero {
  padding: 28rpx 24rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-kicker {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #e64340;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  line-height: 56rpx;
  font-weight: 700;
  color: #222;
}

.hero-add {
  padding: 0 24rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}

.content {
  padding: 0 24rpx 32rpx;
}

.state-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #d4380d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.month-card {
  margin-bottom: 20rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.month-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 12rpx;
}

.month-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.month-count {
  font-size: 22rpx;
  color: #8c8f96;
}

.schedule-item {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 28rpx;
  border-top: 1rpx solid #f3f4f6;
}

.schedule-main {
  width: 120rpx;
  flex-shrink: 0;
}

.schedule-date {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 600;
  color: #222;
}

.schedule-time {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #e64340;
}

.schedule-meta {
  flex: 1;
  min-width: 0;
}

.schedule-name {
  font-size: 26rpx;
  line-height: 36rpx;
  color: #222;
}

.schedule-remark {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8c8f96;
}

.loading-text {
  padding: 18rpx 0 26rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}
