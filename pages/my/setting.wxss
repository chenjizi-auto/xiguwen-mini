page {
  background: #f5f5f5;
}

.setting-page {
  min-height: 100vh;
  padding: 32rpx 0 calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.setting-card {
  margin-top: 32rpx;
  background: #ffffff;
}

.setting-card--single {
  margin-top: 0;
}

.setting-card--logout {
  margin-top: 32rpx;
}

.setting-item {
  min-height: 100rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.setting-item__title {
  font-size: 32rpx;
  color: #222222;
  line-height: 44rpx;
}

.setting-item__title--danger {
  width: 100%;
  text-align: center;
  color: #e5443d;
}

.setting-item__arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #c7c7cc;
  border-right: 3rpx solid #c7c7cc;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.setting-item--logout {
  justify-content: center;
}

.setting-divider {
  margin-left: 32rpx;
  height: 1rpx;
  background: #f0f0f0;
  transform: scaleY(0.5);
  transform-origin: center;
}
