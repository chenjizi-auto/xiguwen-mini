.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.hero {
  padding: 28rpx 24rpx 20rpx;
  background: #fff;
}

.hero-kicker {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #e64340;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  line-height: 56rpx;
  font-weight: 700;
  color: #222;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #8c8f96;
}

.content {
  padding: 20rpx 24rpx 32rpx;
}

.state-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #d4380d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.auth-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.auth-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.auth-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.auth-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #6b7280;
}

.auth-badge {
  flex-shrink: 0;
  align-self: flex-start;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 30rpx;
  color: #e64340;
  background: rgba(230, 67, 64, 0.08);
}

.auth-stars {
  margin-top: 16rpx;
}

.auth-star {
  margin-right: 6rpx;
  font-size: 28rpx;
  line-height: 38rpx;
  color: #ffb21d;
}

.auth-footer {
  margin-top: 22rpx;
  display: flex;
  justify-content: flex-end;
}

.auth-action {
  min-width: 180rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}

.loading-text {
  padding: 18rpx 0 26rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}
