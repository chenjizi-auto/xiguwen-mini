.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.loading-text {
  padding: 120rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #8c8f96;
}

.card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.section-action {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #e64340;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 40rpx;
  color: #222;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.photo-wrap {
  position: relative;
}

.photo-item {
  width: 100%;
  height: 200rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.photo-remove {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 28rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.48);
}

.tips {
  font-size: 22rpx;
  line-height: 34rpx;
  color: #8c8f96;
}

.actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.action-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}

.action-btn--disabled {
  opacity: 0.7;
}
