<view class="page">
  <block wx:if="{{loading && !detail}}">
    <view class="loading-text">加载中...</view>
  </block>

  <block wx:elif="{{detail}}">
    <scroll-view scroll-y class="scroll">
      <view class="hero-card">
        <image class="hero-cover" src="{{detail.logo || defaultCover}}" mode="aspectFill" bindtap="previewLogo" />
        <view class="hero-mask"></view>
        <view class="hero-content">
          <view class="hero-kicker">店铺主页预览</view>
          <view class="hero-title">{{detail.name}}</view>
          <view class="hero-tags">
            <view class="hero-tag">店铺ID {{detail.storeId}}</view>
            <view class="hero-tag hero-tag--light">{{detail.occupation}}</view>
          </view>
        </view>
      </view>

      <view class="card">
        <view class="section-title">店铺概览</view>
        <view class="info-row">
          <view class="info-label">服务区域</view>
          <view class="info-value">{{detail.areaText}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">详细地址</view>
          <view class="info-value">{{detail.address}}</view>
        </view>
        <view class="info-row" wx:if="{{detail.contact}}">
          <view class="info-label">联系电话</view>
          <view class="info-value">{{detail.contact}}</view>
        </view>
      </view>

      <view class="card">
        <view class="section-title">店铺介绍</view>
        <view class="section-text">{{detail.intro || '暂无店铺介绍'}}</view>
      </view>

      <view class="card">
        <view class="section-title">快捷管理</view>
        <view class="action-grid">
          <view class="action-item" wx:for="{{quickActions}}" wx:key="id" data-id="{{item.id}}" bindtap="onQuickActionTap">
            <view class="action-name">{{item.title}}</view>
            <view class="action-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>

      <view class="card">
        <view class="section-title">店铺相册</view>
        <view wx:if="{{detail.photos.length}}" class="photo-grid">
          <image
            wx:for="{{detail.photos}}"
            wx:key="*this"
            class="photo-item"
            src="{{item}}"
            mode="aspectFill"
            data-url="{{item}}"
            bindtap="previewPhoto"
          />
        </view>
        <van-empty wx:else image="/images/empty/nodata.webp" description="暂无店铺图片" />
      </view>

      <view class="safe-area"></view>
    </scroll-view>
  </block>

  <block wx:else>
    <view class="page-inner">
      <view class="state-error" wx:if="{{errorText}}">{{errorText}}</view>
      <van-empty image="/images/empty/nodata.webp" description="暂无店铺主页数据" />
    </view>
  </block>
</view>
