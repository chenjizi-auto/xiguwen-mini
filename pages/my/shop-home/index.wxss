.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.scroll {
  height: 100vh;
}

.loading-text {
  padding-top: 200rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8c8f96;
}

.page-inner {
  padding: 120rpx 24rpx 40rpx;
}

.hero-card {
  position: relative;
  margin: 24rpx;
  height: 360rpx;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 48rpx rgba(19, 27, 42, 0.12);
}

.hero-cover,
.hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-mask {
  background: linear-gradient(180deg, rgba(20, 20, 20, 0.08) 0%, rgba(20, 20, 20, 0.62) 100%);
}

.hero-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx;
  color: #fff;
}

.hero-kicker {
  font-size: 22rpx;
  line-height: 32rpx;
  opacity: 0.88;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 54rpx;
  font-weight: 700;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.hero-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 30rpx;
  background: rgba(255, 255, 255, 0.22);
}

.hero-tag--light {
  background: rgba(255, 255, 255, 0.14);
}

.card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.section-text {
  font-size: 24rpx;
  line-height: 38rpx;
  color: #5f6368;
}

.info-row {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f6f8;
}

.info-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.info-label {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}

.info-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #222;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.action-item {
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff7f6 0%, #fff 100%);
  border: 1rpx solid #fde0dd;
}

.action-name {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 600;
  color: #222;
}

.action-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8c8f96;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.photo-item {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  background: #f5f6f8;
}

.state-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #d4380d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.safe-area {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
