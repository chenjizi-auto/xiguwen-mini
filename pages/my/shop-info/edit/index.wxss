.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.loading-text {
  padding: 120rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #8c8f96;
}

.scroll {
  min-height: 100vh;
  padding: 24rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.section-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-action {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #e64340;
}

.cover-upload {
  position: relative;
  margin-top: 18rpx;
  height: 280rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.cover-upload__img {
  width: 100%;
  height: 100%;
}

.cover-upload__mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #fff;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.55) 100%);
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.form-row:last-child {
  border-bottom: 0;
}

.form-label {
  flex-shrink: 0;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #8c8f96;
}

.form-input,
.picker-value,
.readonly-value {
  flex: 1;
  min-height: 36rpx;
  text-align: right;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #222;
}

.textarea {
  width: 100%;
  min-height: 240rpx;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 40rpx;
  color: #222;
}

.region-group {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.region-picker {
  min-width: 120rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 30rpx;
  color: #4b5563;
  background: #f6f7fb;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.photo-wrap {
  position: relative;
}

.photo-item {
  width: 100%;
  height: 200rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.photo-remove {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 28rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.48);
}

.tips {
  padding: 0 8rpx;
  font-size: 22rpx;
  line-height: 34rpx;
  color: #8c8f96;
}

.safe-area {
  height: 24rpx;
}

.actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.action-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
  box-shadow: 0 14rpx 30rpx rgba(230, 67, 64, 0.24);
}

.action-btn--disabled {
  opacity: 0.7;
}
