<view class="page">
  <block wx:if="{{loading && !detail}}">
    <view class="loading-text">加载中...</view>
  </block>

  <block wx:elif="{{detail}}">
    <scroll-view scroll-y class="scroll">
      <view class="hero-card">
        <image class="hero-cover" src="{{detail.background || defaultCover}}" mode="aspectFill" bindtap="previewBackground" />
        <view class="hero-mask"></view>
        <view class="hero-content">
          <view class="hero-kicker">店铺信息</view>
          <view class="hero-title">{{detail.name}}</view>
          <view class="hero-tags">
            <view class="hero-tag">{{detail.teamText}}</view>
            <view class="hero-tag hero-tag--light">{{detail.statusText}}</view>
          </view>
        </view>
      </view>

      <view class="card">
        <view class="info-row">
          <view class="info-label">店铺ID</view>
          <view class="info-value">{{detail.shopId}}</view>
        </view>
        <view class="info-row" wx:if="{{detail.usertype === 2}}">
          <view class="info-label">职业类别</view>
          <view class="info-value">{{detail.occupation}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">服务区域</view>
          <view class="info-value">{{detail.areaText}}</view>
        </view>
        <view class="info-row">
          <view class="info-label">详细地址</view>
          <view class="info-value">{{detail.address}}</view>
        </view>
      </view>

      <view class="card">
        <view class="section-title">店铺介绍</view>
        <view class="section-text">{{detail.content || '暂无店铺介绍'}}</view>
      </view>

      <view class="card">
        <view class="section-title">店铺图片</view>
        <view wx:if="{{detail.photos.length}}" class="photo-grid">
          <image
            wx:for="{{detail.photos}}"
            wx:key="*this"
            class="photo-item"
            src="{{item}}"
            mode="aspectFill"
            data-url="{{item}}"
            bindtap="previewPhoto"
          />
        </view>
        <van-empty wx:else image="/images/empty/nodata.webp" description="暂无店铺图片" />
      </view>

      <view class="safe-area"></view>
    </scroll-view>
    <view class="actions">
      <view class="action-btn" bindtap="goEdit">编辑店铺信息</view>
    </view>
  </block>

  <block wx:else>
    <view class="page-inner">
      <view class="state-error" wx:if="{{errorText}}">{{errorText}}</view>
      <van-empty image="/images/empty/nodata.webp" description="暂无店铺信息" />
    </view>
  </block>
</view>
