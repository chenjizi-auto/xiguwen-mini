.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.page-inner,
.scroll {
  min-height: 100vh;
}

.scroll {
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.loading-text {
  padding: 120rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #8c8f96;
}

.hero-card {
  position: relative;
  height: 360rpx;
  margin: 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(19, 27, 42, 0.12);
}

.hero-cover {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(18, 18, 18, 0.08) 0%, rgba(18, 18, 18, 0.6) 100%);
}

.hero-content {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  color: #fff;
}

.hero-kicker {
  font-size: 22rpx;
  line-height: 32rpx;
  opacity: 0.88;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 700;
}

.hero-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.hero-tag {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 22rpx;
  line-height: 30rpx;
}

.hero-tag--light {
  background: rgba(255, 255, 255, 0.14);
}

.card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  flex-shrink: 0;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #8c8f96;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  line-height: 36rpx;
  color: #222;
  word-break: break-all;
}

.section-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.section-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 42rpx;
  color: #4b5563;
  white-space: pre-wrap;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.photo-item {
  width: 100%;
  height: 200rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.state-error {
  margin: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #d4380d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.safe-area {
  height: 24rpx;
}

.actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.action-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
  box-shadow: 0 14rpx 30rpx rgba(230, 67, 64, 0.24);
}
