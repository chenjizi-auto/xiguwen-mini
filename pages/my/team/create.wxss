.create-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.form-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.upload-row,
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
}

.upload-row {
  padding: 12rpx 0;
}

.form-row--top {
  align-items: flex-start;
  padding-top: 8rpx;
}

.upload-copy,
.form-label {
  flex: 1;
  min-width: 0;
}

.upload-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.upload-title {
  font-size: 28rpx;
  line-height: 40rpx;
  color: #222;
}

.upload-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #7b7f87;
}

.upload-thumb {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: #f3f4f6;
  display: block;
  flex-shrink: 0;
}

.upload-thumb--logo {
  border-radius: 20rpx;
}

.upload-thumb--wide {
  border-radius: 20rpx;
  transform: translateY(12rpx) scale(1.04);
}

.upload-thumb-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 24rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f7f8fa 0%, #eef1f5 100%);
}

.upload-thumb-wrap--logo {
  width: 168rpx;
  height: 96rpx;
  border-radius: 20rpx;
}

.upload-thumb-wrap--background {
  width: 220rpx;
  height: 120rpx;
  border-radius: 20rpx;
}

.form-label {
  width: 160rpx;
  flex: 0 0 160rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #222;
}

.form-input,
.form-value {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #222;
  text-align: right;
}

.form-value--placeholder {
  color: #b0b3b8;
}

.form-textarea {
  flex: 1;
  min-width: 0;
  height: 220rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  border: 1rpx solid #e5e6eb;
  border-radius: 20rpx;
  background: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #222;
}

.form-divider {
  height: 1rpx;
  background: #f3f4f6;
}

.submit-bar {
  margin-top: 40rpx;
}
