<view class="day-page">
  <view class="toolbar-card">
    <view class="toolbar-head">
      <view class="toolbar-title">{{title}}</view>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="toolbar-date">{{date}}</view>
      </picker>
    </view>
    <view class="toolbar-actions">
      <van-button size="small" plain type="primary" bind:click="onPrevDay">前一天</van-button>
      <van-button size="small" plain type="primary" bind:click="onNextDay">后一天</van-button>
    </view>
  </view>

  <view class="state-error" wx:if="{{errorText}}">{{errorText}}</view>

  <block wx:if="{{list.length}}">
    <view class="record-card" wx:for="{{list}}" wx:key="index">
      <view class="record-name">{{item.nickname}}</view>
      <view class="record-meta">{{item.date}} · {{item.timeslotText}}</view>
      <view class="record-time">{{item.createTime}}</view>
    </view>
  </block>

  <van-empty wx:if="{{!loading && !errorText && list.length === 0}}" image="search" description="暂无数据" />
  <view class="loading-text" wx:if="{{loading}}">加载中...</view>
</view>
