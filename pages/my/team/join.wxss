.join-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.search-card,
.club-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.search-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #f7f8fa;
  font-size: 28rpx;
  color: #222;
}

.search-btn {
  flex-shrink: 0;
  padding: 0 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 18rpx;
  background: #e64340;
  color: #fff;
  font-size: 26rpx;
}

.state-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #d4380d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.club-cover {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
}

.club-main {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.club-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #f3f4f6;
  flex-shrink: 0;
}

.club-content {
  flex: 1;
  min-width: 0;
}

.club-name {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.club-type,
.club-region,
.club-profile {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #7b7f87;
}

.club-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 24rpx;
}

.club-members {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}

.club-action {
  min-width: 160rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #e64340;
  color: #fff;
  font-size: 24rpx;
  line-height: 32rpx;
}

.club-action--disabled {
  background: #f1f3f5;
  color: #8c8f96;
}

.loading-text {
  padding: 24rpx 0;
  text-align: center;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}
