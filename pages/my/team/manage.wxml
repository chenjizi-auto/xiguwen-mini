<view class="manage-page">
  <view class="search-card">
    <van-search
      value="{{keyword}}"
      placeholder="搜索团队成员"
      shape="round"
      bind:change="onSearchChange"
      bind:search="onSearch"
      bind:clear="onSearch"
    />
  </view>

  <view class="state-error" wx:if="{{errorText}}">{{errorText}}</view>

  <block wx:if="{{list.length}}">
    <view class="member-card" wx:for="{{list}}" wx:key="id">
      <view class="member-main">
        <image class="member-avatar" src="{{item.head || '/images/default.webp'}}" mode="aspectFill"></image>
        <view class="member-copy">
          <view class="member-row">
            <view class="member-name">{{item.nickname}}</view>
            <view class="member-role member-role--{{item.role}}">{{item.roleText}}</view>
          </view>
          <view class="member-meta">{{item.occupation}}</view>
          <view class="member-meta">{{item.address}}</view>
        </view>
      </view>
      <view class="member-actions">
        <van-button
          wx:if="{{myRole === 1 && item.role === 3}}"
          size="small"
          plain
          type="primary"
          bind:click="onSetAdminTap"
          data-id="{{item.id}}"
          data-index="{{index}}"
          loading="{{submittingId === item.id}}"
        >设为管理员</van-button>
        <van-button
          wx:if="{{myRole === 1 && item.role === 2}}"
          size="small"
          plain
          type="warning"
          bind:click="onCancelAdminTap"
          data-id="{{item.id}}"
          data-index="{{index}}"
          loading="{{submittingId === item.id}}"
        >取消管理员</van-button>
        <van-button
          wx:if="{{(myRole === 1 && item.role !== 1) || (myRole === 2 && item.role === 3)}}"
          size="small"
          type="danger"
          bind:click="onDeleteTap"
          data-id="{{item.id}}"
          data-index="{{index}}"
          loading="{{submittingId === item.id}}"
        >移除成员</van-button>
      </view>
    </view>
  </block>

  <van-empty wx:if="{{!loading && !errorText && list.length === 0}}" image="search" description="暂无成员数据" />
  <view class="loading-text" wx:if="{{loading}}">加载中...</view>
</view>
