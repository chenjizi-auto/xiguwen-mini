<view class="schedule-page">
  <view class="page-head">
    <view class="page-title">全部成员（{{list.length}}）</view>
    <view class="page-desc">查看当前团队成员档期概况</view>
  </view>

  <view class="state-error" wx:if="{{errorText}}">{{errorText}}</view>

  <block wx:if="{{list.length}}">
    <view class="member-card" wx:for="{{list}}" wx:key="userId">
      <image class="member-avatar" src="{{item.head || '/images/default.webp'}}" mode="aspectFill"></image>
      <view class="member-copy">
        <view class="member-name">{{item.nickname}}</view>
        <view class="member-meta">{{item.occupation}}</view>
        <view class="member-price">最低价 ¥{{item.minPrice}}</view>
      </view>
    </view>
  </block>

  <van-empty wx:if="{{!loading && !errorText && list.length === 0}}" image="search" description="暂无成员档期数据" />
  <view class="loading-text" wx:if="{{loading}}">加载中...</view>
</view>
