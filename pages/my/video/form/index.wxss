@import "/pages/my/mine-atlas-edit/index.wxss";

.mode-tabs {
  display: flex;
  gap: 20rpx;
}

.mode-tab {
  min-width: 160rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  background: #f3f4f6;
}

.mode-tab--active {
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}

.video-file-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff7f6;
}

.video-file-name {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #222;
  word-break: break-all;
}

.video-file-action {
  min-width: 96rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  color: #e64340;
  background: #fff1f0;
}
