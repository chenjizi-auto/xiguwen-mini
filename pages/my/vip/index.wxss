.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.16), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.hero {
  margin-bottom: 24rpx;
  padding: 34rpx 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #1f2937 0%, #3f3d56 100%);
  color: #fff;
}

.hero-kicker {
  font-size: 24rpx;
  line-height: 34rpx;
  opacity: 0.82;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 44rpx;
  line-height: 58rpx;
  font-weight: 700;
}

.hero-sub {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 38rpx;
  opacity: 0.86;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.status-badge {
  min-width: 132rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #8c8f96;
  background: #f3f4f6;
}

.status-badge--on {
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}

.status-text {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #666;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.benefit-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.benefit-item {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #4b5563;
  background: #f3f4f6;
}

.plan-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7f8fa;
  border: 2rpx solid transparent;
}

.plan-item--active {
  background: #fff7f6;
  border-color: #f06b62;
}

.plan-name {
  font-size: 28rpx;
  line-height: 40rpx;
  color: #222;
}

.plan-price {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 700;
  color: #e64340;
}

.submit-wrap {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.submit-btn {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #f06b62 0%, #e64340 100%);
}

.submit-btn--disabled {
  background: #c7cad1;
}
