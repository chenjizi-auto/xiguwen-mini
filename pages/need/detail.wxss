.detail-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(184rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.state-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #d4380d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.detail-card,
.section-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.detail-type {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1ef;
  color: #e64340;
  font-size: 22rpx;
  line-height: 30rpx;
}

.detail-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 700;
  color: #222;
}

.detail-price {
  margin-top: 16rpx;
  font-size: 40rpx;
  line-height: 52rpx;
  font-weight: 700;
  color: #e64340;
}

.detail-countdown {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #7b7f87;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.detail-grid__item {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f7f8fa;
  min-width: 0;
}

.detail-grid__label {
  font-size: 22rpx;
  line-height: 30rpx;
  color: #8c8f96;
}

.detail-grid__value {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 600;
  color: #222;
}

.detail-grid__item--code {
  grid-column: 1;
}

.detail-grid__value--code {
  font-size: 24rpx;
  line-height: 34rpx;
  word-break: break-all;
}

.section-title {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 600;
  color: #222;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f3f4f6;
}

.detail-row:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.detail-row__label {
  flex: 0 0 150rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}

.detail-row__value,
.detail-row__content {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 26rpx;
  line-height: 38rpx;
  color: #222;
}

.detail-row--column {
  display: block;
}

.detail-row--column .detail-row__content {
  margin-top: 12rpx;
  text-align: left;
}

.remark-textarea {
  width: 100%;
  height: 180rpx;
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  color: #222;
}

.action-btn {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 26rpx;
  line-height: 34rpx;
}

.action-btn--light {
  background: #fff;
  color: #4e5969;
  border: 1rpx solid #e5e6eb;
}

.action-btn--danger {
  background: #e64340;
  color: #fff;
}

.action-btn--disabled {
  background: #f1f3f5;
  color: #8c8f96;
}

.loading-text {
  padding: 24rpx 0;
  text-align: center;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(247, 248, 250, 0.96);
  backdrop-filter: blur(12rpx);
  box-sizing: border-box;
}

.bottom-bar__inner {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 -8rpx 32rpx rgba(19, 27, 42, 0.08);
}
