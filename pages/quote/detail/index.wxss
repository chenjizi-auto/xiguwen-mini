.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 32rpx;
}

.hero-swiper,
.hero-single {
  width: 100%;
  height: 440rpx;
}

.hero-image {
  width: 100%;
  height: 440rpx;
}

.card {
  margin: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2329;
  line-height: 1.5;
}

.price {
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8c8c8c;
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: 202rpx;
  height: 202rpx;
  border-radius: 16rpx;
}

.loading-text {
  padding: 120rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}
