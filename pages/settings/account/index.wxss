page {
  background: #f5f5f5;
}

.account-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.account-hero {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.18), transparent 28%),
    linear-gradient(135deg, #d9554b 0%, #f29c6b 100%);
  box-shadow: 0 16rpx 32rpx rgba(217, 85, 75, 0.18);
}

.account-hero__label {
  color: rgba(255, 255, 255, 0.84);
  font-size: 22rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.account-hero__title {
  margin-top: 10rpx;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
}

.account-hero__desc {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  line-height: 1.8;
}

.account-card {
  margin-top: 24rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.account-item {
  min-height: 104rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.account-item__title {
  font-size: 30rpx;
  color: #222222;
}

.account-item__title--danger {
  color: #e5443d;
}

.account-item__right {
  display: flex;
  align-items: center;
}

.account-item__status {
  font-size: 26rpx;
  color: #8c8c8c;
}

.account-item__arrow {
  width: 16rpx;
  height: 16rpx;
  margin-left: 16rpx;
  border-top: 3rpx solid #c7c7cc;
  border-right: 3rpx solid #c7c7cc;
  transform: rotate(45deg);
}

.account-divider {
  margin-left: 28rpx;
  height: 1rpx;
  background: #f0f0f0;
}

.account-tip {
  padding: 0 8rpx;
  font-size: 24rpx;
  line-height: 38rpx;
  color: #999999;
}
