page {
  background: #f5f5f5;
}

.address-edit-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.form-card {
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.form-item {
  min-height: 104rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.form-item--textarea {
  padding-top: 28rpx;
  padding-bottom: 28rpx;
  align-items: flex-start;
}

.form-item__label {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 30rpx;
  color: #222222;
}

.form-item__input,
.form-item__value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 28rpx;
  color: #333333;
}

.form-item__value--placeholder {
  color: #b6b6b6;
}

.form-item__textarea {
  flex: 1;
  height: 160rpx;
  font-size: 28rpx;
  color: #333333;
}

.form-divider {
  margin-left: 28rpx;
  height: 1rpx;
  background: #f0f0f0;
}

.submit-btn {
  margin-top: 48rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #e5443d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 30rpx rgba(229, 68, 61, 0.22);
}
