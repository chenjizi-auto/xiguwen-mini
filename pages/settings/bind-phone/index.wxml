<view class="bind-page">
  <view class="bind-step">
    <view class="bind-step__item {{step >= 1 ? 'bind-step__item--active' : ''}}">1. 验证原手机号</view>
    <view class="bind-step__line"></view>
    <view class="bind-step__item {{step >= 2 ? 'bind-step__item--active' : ''}}">2. 绑定新手机号</view>
  </view>

  <block wx:if="{{step === 1}}">
    <view class="bind-card">
      <view class="bind-row">
        <input class="bind-row__input" type="number" value="{{oldPhone}}" placeholder="请输入当前手机号" disabled="{{oldPhoneReadonly}}" bindinput="onOldPhoneInput" />
        <view class="bind-row__code-btn {{oldCountdown ? 'bind-row__code-btn--disabled' : ''}}" bindtap="onSendOldCode">{{oldCountdown ? oldCountdown + 's' : '获取验证码'}}</view>
      </view>
      <view class="bind-divider"></view>
      <view class="bind-row">
        <input class="bind-row__input" type="number" value="{{oldCode}}" placeholder="请输入验证码" bindinput="onOldCodeInput" />
      </view>
    </view>
    <view class="bind-submit" bindtap="onVerifyOld">下一步</view>
  </block>

  <block wx:if="{{step === 2}}">
    <view class="bind-card">
      <view class="bind-row">
        <input class="bind-row__input" type="number" value="{{newPhone}}" placeholder="请输入新手机号" bindinput="onNewPhoneInput" />
        <view class="bind-row__code-btn {{newCountdown ? 'bind-row__code-btn--disabled' : ''}}" bindtap="onSendNewCode">{{newCountdown ? newCountdown + 's' : '获取验证码'}}</view>
      </view>
      <view class="bind-divider"></view>
      <view class="bind-row">
        <input class="bind-row__input" type="number" value="{{newCode}}" placeholder="请输入验证码" bindinput="onNewCodeInput" />
      </view>
    </view>
    <view class="bind-submit" bindtap="onSubmitNewPhone">立即绑定</view>
  </block>
</view>
