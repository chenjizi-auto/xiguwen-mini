page {
  background: #f5f5f5;
}

.profile-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.profile-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.profile-item {
  min-height: 104rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.profile-item--avatar {
  min-height: 144rpx;
}

.profile-item--textarea {
  padding-top: 28rpx;
  padding-bottom: 28rpx;
  align-items: flex-start;
}

.profile-item__label {
  width: 156rpx;
  flex-shrink: 0;
  font-size: 30rpx;
  color: #222222;
}

.profile-item__input,
.profile-item__value {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.profile-item__value--placeholder {
  color: #b6b6b6;
}

.profile-avatar-wrap {
  display: flex;
  align-items: center;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f2f2f2;
}

.profile-item__arrow {
  width: 16rpx;
  height: 16rpx;
  margin-left: 16rpx;
  border-top: 3rpx solid #c7c7cc;
  border-right: 3rpx solid #c7c7cc;
  transform: rotate(45deg);
}

.profile-item__textarea {
  flex: 1;
  height: 160rpx;
  font-size: 28rpx;
  color: #333333;
}

.profile-divider {
  margin-left: 28rpx;
  height: 1rpx;
  background: #f0f0f0;
}

.profile-submit {
  margin-top: 48rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #e5443d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 30rpx rgba(229, 68, 61, 0.22);
}
