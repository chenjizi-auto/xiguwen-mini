page {
  background: #f5f5f5;
}

.security-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.security-hero {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.18), transparent 28%),
    linear-gradient(135deg, #2f3f66 0%, #506ea8 100%);
  box-shadow: 0 16rpx 32rpx rgba(47, 63, 102, 0.16);
}

.security-hero__label {
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.security-hero__title {
  margin-top: 10rpx;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
}

.security-hero__desc {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  line-height: 1.8;
}

.security-card {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.security-item {
  min-height: 104rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.security-item__title {
  font-size: 30rpx;
  color: #222222;
}

.security-item__desc {
  margin-left: auto;
  margin-right: 16rpx;
  font-size: 24rpx;
  color: #8c8c8c;
}

.security-item__arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #c7c7cc;
  border-right: 3rpx solid #c7c7cc;
  transform: rotate(45deg);
}

.security-divider {
  margin-left: 28rpx;
  height: 1rpx;
  background: #f0f0f0;
}

.security-tip {
  margin-top: 24rpx;
  padding: 0 8rpx;
  font-size: 24rpx;
  line-height: 38rpx;
  color: #999999;
}
