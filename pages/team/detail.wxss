.team-detail-page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f7f3ee 0%, #ffffff 30%, #f7f7f7 100%);
  box-sizing: border-box;
}

.state-error,
.loading-text {
  margin-top: 40rpx;
  color: #8a4d33;
  text-align: center;
  font-size: 28rpx;
}

.hero-card {
  position: relative;
  min-height: 280rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: #c8ae92;
  box-shadow: 0 20rpx 48rpx rgba(63, 40, 23, 0.12);
}

.hero-cover,
.hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-mask {
  background: linear-gradient(135deg, rgba(41, 26, 16, 0.18), rgba(41, 26, 16, 0.7));
}

.hero-main {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  min-height: 280rpx;
  box-sizing: border-box;
}

.hero-logo {
  width: 132rpx;
  height: 132rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.85);
  flex-shrink: 0;
}

.hero-copy {
  margin-left: 24rpx;
  color: #fff;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 600;
  line-height: 1.3;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.hero-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.hero-address {
  margin-top: 18rpx;
  font-size: 24rpx;
  opacity: 0.92;
}

.stats-card,
.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 14rpx 34rpx rgba(34, 26, 18, 0.06);
}

.stats-card {
  display: flex;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-num {
  color: #7f4e2f;
  font-size: 38rpx;
  font-weight: 600;
}

.stats-label {
  margin-top: 10rpx;
  color: #8d877f;
  font-size: 24rpx;
}

.section-title {
  color: #2c2119;
  font-size: 30rpx;
  font-weight: 600;
}

.section-content {
  margin-top: 18rpx;
  color: #5a5048;
  font-size: 26rpx;
  line-height: 1.8;
}

.dynamic-item + .dynamic-item {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #f0ece8;
}

.dynamic-head {
  display: flex;
  align-items: center;
}

.dynamic-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #f4f4f4;
  flex-shrink: 0;
}

.dynamic-meta {
  margin-left: 18rpx;
  min-width: 0;
}

.dynamic-name {
  color: #2e2219;
  font-size: 28rpx;
  font-weight: 600;
}

.dynamic-sub {
  margin-top: 8rpx;
  color: #9c948d;
  font-size: 22rpx;
}

.dynamic-content {
  margin-top: 18rpx;
  color: #4f4640;
  font-size: 26rpx;
  line-height: 1.8;
  overflow: hidden;
}

.dynamic-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.dynamic-image {
  width: 206rpx;
  height: 206rpx;
  border-radius: 20rpx;
  background: #f4f4f4;
}

.dynamic-footer {
  display: flex;
  gap: 28rpx;
  margin-top: 16rpx;
  color: #a39b94;
  font-size: 22rpx;
}
