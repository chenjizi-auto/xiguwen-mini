<view class="flow-page">
  <view class="hero-card">
    <view class="hero-kicker">Wedding Flow</view>
    <view class="hero-title">婚礼流程</view>
    <view class="hero-desc">按时间梳理婚礼当天的关键事项、负责人员和执行节点。</view>
    <van-button type="primary" size="small" bind:click="onAddTap">新增流程</van-button>
  </view>

  <view class="state-error" wx:if="{{loadError}}">{{loadError}}</view>

  <block wx:if="{{list.length}}">
    <view class="flow-card" wx:for="{{list}}" wx:key="id">
      <view class="flow-head">
        <view class="flow-time">{{item.time}}</view>
        <view class="flow-title">{{item.title}}</view>
      </view>
      <view class="flow-row" wx:if="{{item.person}}">
        <text class="flow-label">人员</text>
        <text class="flow-value">{{item.person}}</text>
      </view>
      <view class="flow-row" wx:if="{{item.matter}}">
        <text class="flow-label">事项</text>
        <text class="flow-value">{{item.matter}}</text>
      </view>
      <view class="flow-actions">
        <van-button plain type="primary" size="small" bind:click="onEditTap" data-item="{{item}}">编辑</van-button>
        <van-button plain type="danger" size="small" bind:click="onDeleteTap" data-id="{{item.id}}">删除</van-button>
      </view>
    </view>
  </block>

  <van-empty wx:if="{{!loading && !loadError && list.length === 0}}" image="search" description="还没有婚礼流程，先添加一条吧" />
  <view class="loading-text" wx:if="{{loading}}">加载中...</view>
</view>
