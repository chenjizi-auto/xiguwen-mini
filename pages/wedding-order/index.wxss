.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(230, 67, 64, 0.14), transparent 34%),
    linear-gradient(180deg, #fff7f6 0%, #f7f8fa 220rpx, #f7f8fa 100%);
}

.hero {
  padding: 24rpx 24rpx 20rpx;
  background: transparent;
}

.hero-top {
  padding: 28rpx 28rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fff1ef 100%);
  box-shadow: 0 12rpx 36rpx rgba(229, 89, 79, 0.08);
}

.hero-kicker {
  font-size: 22rpx;
  line-height: 32rpx;
  color: #e26b63;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  line-height: 52rpx;
  font-weight: 600;
  color: #222;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #7b7f87;
}

.content {
  padding: 20rpx 24rpx 48rpx;
}

.state-error {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1f0;
  color: #d4380d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.order-card {
  margin-bottom: 20rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(19, 27, 42, 0.05);
}

.order-card__hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.order-sn {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 32rpx;
  color: #8c8f96;
}

.order-status {
  margin-left: 20rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 600;
  color: #e64340;
}

.order-main {
  display: flex;
  padding: 24rpx 28rpx 28rpx;
}

.order-cover {
  width: 136rpx;
  height: 136rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
  flex-shrink: 0;
}

.order-meta {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.order-title {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 600;
  color: #222;
}

.order-spec {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #7b7f87;
}

.order-price {
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  color: #e64340;
}

.order-card__ft {
  display: flex;
  justify-content: flex-end;
  padding: 0 28rpx 24rpx;
}

.order-refund {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff4e8;
  color: #d46b08;
  font-size: 22rpx;
  line-height: 30rpx;
}

.loading-text {
  padding: 12rpx 0 18rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 34rpx;
  color: #8c8f96;
}
